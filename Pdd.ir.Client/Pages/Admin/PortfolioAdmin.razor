@page "/admin/portfolio"
@inject HttpClient Http
@inject ITranslateService T
@inject IJSRuntime JS

<PageTitle>@T.Text("admin_portfolio") | PDD</PageTitle>

<div class="d-flex align-items-center justify-between mb-4" style="padding-top:24px;">
    <div>
        <h1 style="font-size:28px;font-weight:700;">@T.Text("admin_portfolio")</h1>
        <p class="text-muted" style="font-size:14px;">@(T.CurrentLanguage == "fa" ? "ایجاد و مدیریت پروژه‌ها" : "Create and manage projects")</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreateDialog">
        <i class="bi bi-plus-lg me-1"></i>@(T.CurrentLanguage == "fa" ? "نمونه کار جدید" : "New Portfolio")
    </button>
</div>

<section class="section" style="padding-top:0;">
    <div class="container">
        <div class="card">
            @if (_items == null)
            {
                @for (int i = 0; i < 3; i++)
                {
                    <div class="skeleton skeleton-row mb-2"></div>
                }
            }
            else if (!_items.Any())
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-images" style="font-size:2rem;"></i>
                    <p class="mt-2">@T.Text("no_data")</p>
                </div>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table style="width:100%;border-collapse:collapse;">
                        <thead>
                            <tr style="border-bottom:1px solid var(--pdd-border);">
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">#</th>
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "عنوان" : "Title")</th>
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "دسته‌بندی" : "Category")</th>
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "ترتیب" : "Order")</th>
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "وضعیت" : "Status")</th>
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "عملیات" : "Actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _items)
                            {
                                <tr style="border-bottom:1px solid var(--pdd-border);">
                                    <td style="padding:12px;font-size:14px;">@item.Id</td>
                                    <td style="padding:12px;font-size:14px;">@item.Title</td>
                                    <td style="padding:12px;"><span style="padding:4px 10px;background:var(--pdd-primary-glow);color:var(--pdd-primary);border-radius:100px;font-size:12px;font-weight:600;">@item.Category</span></td>
                                    <td style="padding:12px;font-size:14px;">@item.SortOrder</td>
                                    <td style="padding:12px;">
                                        @if (item.IsActive)
                                        {
                                            <span style="padding:4px 10px;background:rgba(34,197,94,0.15);color:#22c55e;border-radius:100px;font-size:12px;font-weight:600;">@(T.CurrentLanguage == "fa" ? "فعال" : "Active")</span>
                                        }
                                        else
                                        {
                                            <span style="padding:4px 10px;background:rgba(156,163,175,0.15);color:var(--pdd-text-muted);border-radius:100px;font-size:12px;font-weight:600;">@(T.CurrentLanguage == "fa" ? "غیرفعال" : "Inactive")</span>
                                        }
                                    </td>
                                    <td style="padding:12px;">
                                        <button class="btn btn-sm btn-glass me-1" @onclick="() => OpenEditDialog(item)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-glass" style="color:#ef4444;" @onclick="() => DeleteAsync(item)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

@if (_showDialog)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);z-index:10000;">
        <div class="modal-dialog modal-lg">
            <div class="modal-content" style="background:var(--pdd-bg-2);border:1px solid var(--pdd-border);border-radius:var(--pdd-radius-lg);">
                <div class="modal-header" style="border-bottom:1px solid var(--pdd-border);padding:16px 24px;">
                    <h5 class="modal-title" style="font-size:18px;font-weight:600;">@(_editId.HasValue ? (T.CurrentLanguage == "fa" ? "ویرایش نمونه کار" : "Edit Portfolio") : (T.CurrentLanguage == "fa" ? "نمونه کار جدید" : "New Portfolio"))</h5>
                    <button type="button" class="btn btn-sm btn-glass" @onclick="CloseDialog"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="modal-body" style="padding:24px;">
                    <div style="background:var(--pdd-glass);border-radius:12px;padding:12px 16px;margin-bottom:16px;">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                            <i class="bi bi-info-circle" style="color:var(--pdd-primary);"></i>
                            <strong style="font-size:0.875rem;">@(T.CurrentLanguage == "fa" ? "راهنما" : "Guide")</strong>
                        </div>
                        <p style="margin:0;font-size:0.8125rem;color:var(--pdd-text-muted);">
                            @(T.CurrentLanguage == "fa" ? "اطلاعات نمونه کار را وارد کنید." : "Enter portfolio information.")
                        </p>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr;gap:16px;">
                        <div>
                            <label class="form-label">@(T.CurrentLanguage == "fa" ? "عنوان" : "Title") *</label>
                            <input class="form-control" @bind="_model.Title" />
                        </div>
                        <div>
                            <label class="form-label">@(T.CurrentLanguage == "fa" ? "توضیحات" : "Description")</label>
                            <textarea class="form-control" rows="3" @bind="_model.Description"></textarea>
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;">
                            <div>
                                <label class="form-label">@(T.CurrentLanguage == "fa" ? "دسته‌بندی" : "Category")</label>
                                <input class="form-control" @bind="_model.Category" />
                            </div>
                            <div>
                                <label class="form-label">@(T.CurrentLanguage == "fa" ? "ترتیب نمایش" : "Sort Order")</label>
                                <input type="number" class="form-control" @bind="_model.SortOrder" />
                            </div>
                            <div>
                                <label class="form-label">@(T.CurrentLanguage == "fa" ? "آدرس تصویر" : "Image URL")</label>
                                <input class="form-control" @bind="_model.ImageUrl" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-top:1px solid var(--pdd-border);padding:16px 24px;display:flex;gap:10px;justify-content:flex-end;">
                    <button class="btn btn-glass" @onclick="CloseDialog">@(T.CurrentLanguage == "fa" ? "انصراف" : "Cancel")</button>
                    <button class="btn btn-primary" @onclick="SaveAsync">
                        <i class="bi bi-floppy me-1"></i>@T.Text("save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<PortfolioDto>? _items;
    private bool _showDialog;
    private int? _editId;
    private PortfolioCreateRequest _model = new();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<PortfolioDto>>>("api/portfolio/admin");
            _items = response?.Data?.ToList();
        }
        catch { _items = new List<PortfolioDto>(); }
    }

    private void OpenCreateDialog()
    {
        _editId = null;
        _model = new PortfolioCreateRequest();
        _showDialog = true;
    }

    private void OpenEditDialog(PortfolioDto item)
    {
        _editId = item.Id;
        _model = new PortfolioCreateRequest
        {
            Title = item.Title, Description = item.Description, ImageUrl = item.ImageUrl,
            ProjectUrl = item.ProjectUrl, Category = item.Category, SortOrder = item.SortOrder, IsActive = item.IsActive
        };
        _showDialog = true;
    }

    private void CloseDialog() { _showDialog = false; StateHasChanged(); }

    private async Task SaveAsync()
    {
        try
        {
            if (_editId.HasValue)
                await Http.PutAsJsonAsync($"api/portfolio/{_editId}", _model);
            else
                await Http.PostAsJsonAsync("api/portfolio", _model);
            CloseDialog();
            await LoadData();
        }
        catch { }
    }

    private async Task DeleteAsync(PortfolioDto item)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"آیا از حذف «{item.Title}» مطمئن هستید؟");
        if (!confirmed) return;
        await Http.DeleteAsync($"api/portfolio/{item.Id}");
        await LoadData();
    }

    public class PortfolioDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string ProjectUrl { get; set; } = "";
        public string Category { get; set; } = "";
        public int SortOrder { get; set; }
        public bool IsActive { get; set; }
    }

    public class PortfolioCreateRequest
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string ProjectUrl { get; set; } = "";
        public string Category { get; set; } = "";
        public int SortOrder { get; set; }
        public bool IsActive { get; set; } = true;
    }

    public class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public T? Data { get; set; }
    }
}
