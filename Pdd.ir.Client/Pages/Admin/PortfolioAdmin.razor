@page "/admin/portfolio"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>مدیریت نمونه کارها | Pdd.ir</PageTitle>

<PageHeader Title="مدیریت نمونه کارها" Subtitle="ایجاد و مدیریت پروژه‌ها">
    <button class="btn btn-primary" @onclick="OpenCreateDialog">
        <i class="bi bi-plus-lg me-1"></i>نمونه کار جدید
    </button>
</PageHeader>

<section class="section">
    <div class="container">
        <div class="admin-card">
            @if (_items == null)
            {
                @for (int i = 0; i < 3; i++)
                {
                    <div class="skeleton skeleton-row mb-2"></div>
                }
            }
            else if (!_items.Any())
            {
                <div class="text-center py-4 text-secondary">
                    <i class="bi bi-images" style="font-size:2rem;"></i>
                    <p class="mt-2">نمونه کاری یافت نشد</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>عنوان</th>
                                <th>دسته‌بندی</th>
                                <th>ترتیب</th>
                                <th>وضعیت</th>
                                <th>عملیات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _items)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.Title</td>
                                    <td><span class="badge bg-primary">@item.Category</span></td>
                                    <td>@item.SortOrder</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">فعال</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">غیرفعال</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => OpenEditDialog(item)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

@if (_showDialog)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content" style="background:var(--bg-secondary);border:1px solid var(--border-color);">
                <div class="modal-header" style="border-color:var(--border-color);">
                    <h5 class="modal-title">@(_editId.HasValue ? "ویرایش نمونه کار" : "نمونه کار جدید")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDialog"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">عنوان *</label>
                            <input class="form-control" @bind="_model.Title" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">توضیحات</label>
                            <textarea class="form-control" rows="3" @bind="_model.Description"></textarea>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">دسته‌بندی</label>
                            <input class="form-control" @bind="_model.Category" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">ترتیب نمایش</label>
                            <input type="number" class="form-control" @bind="_model.SortOrder" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">آدرس تصویر</label>
                            <input class="form-control" @bind="_model.ImageUrl" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-color:var(--border-color);">
                    <button class="btn btn-secondary" @onclick="CloseDialog">انصراف</button>
                    <button class="btn btn-primary" @onclick="SaveAsync">
                        <i class="bi bi-floppy me-1"></i>ذخیره
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<PortfolioDto>? _items;
    private bool _showDialog;
    private int? _editId;
    private PortfolioCreateRequest _model = new();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<PortfolioDto>>>("api/portfolio/admin");
            _items = response?.Data?.ToList();
        }
        catch { _items = new List<PortfolioDto>(); }
    }

    private void OpenCreateDialog()
    {
        _editId = null;
        _model = new PortfolioCreateRequest();
        _showDialog = true;
    }

    private void OpenEditDialog(PortfolioDto item)
    {
        _editId = item.Id;
        _model = new PortfolioCreateRequest
        {
            Title = item.Title, Description = item.Description, ImageUrl = item.ImageUrl,
            ProjectUrl = item.ProjectUrl, Category = item.Category, SortOrder = item.SortOrder, IsActive = item.IsActive
        };
        _showDialog = true;
    }

    private void CloseDialog() { _showDialog = false; StateHasChanged(); }

    private async Task SaveAsync()
    {
        try
        {
            if (_editId.HasValue)
                await Http.PutAsJsonAsync($"api/portfolio/{_editId}", _model);
            else
                await Http.PostAsJsonAsync("api/portfolio", _model);
            CloseDialog();
            await LoadData();
        }
        catch { }
    }

    private async Task DeleteAsync(PortfolioDto item)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"آیا از حذف «{item.Title}» مطمئن هستید؟");
        if (!confirmed) return;
        await Http.DeleteAsync($"api/portfolio/{item.Id}");
        await LoadData();
    }
}
