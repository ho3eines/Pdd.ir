@page "/admin/portfolio"
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IJSRuntime JS

<PageTitle>@(T.CurrentLanguage == "fa" ? "مدیریت نمونه کار" : "Portfolio") | PDD</PageTitle>

<div class="page-enter">
    <div class="d-flex align-items-center justify-content-between mb-4" style="padding-top:24px;">
        <div>
            <h1 style="font-size:28px;font-weight:700;">@(T.CurrentLanguage == "fa" ? "مدیریت نمونه کار" : "Portfolio Management")</h1>
            <p class="text-muted" style="font-size:14px;">@(T.CurrentLanguage == "fa" ? "ایجاد و مدیریت پروژه‌ها" : "Create and manage projects")</p>
        </div>
        <button class="btn btn-primary" @onclick="OpenCreateDialog">
            <i class="bi bi-plus-lg me-1"></i>@(T.CurrentLanguage == "fa" ? "نمونه کار جدید" : "New Portfolio")
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="skeleton skeleton-card" style="height:400px;"></div>
    }
    else
    {
        <div class="glass-card fade-slide-in" style="padding:20px;">
            <div class="d-flex align-items-center gap-2 mb-3">
                <div class="flex-grow-1">
                    <input type="text" class="form-control" placeholder="جستجو..."
                           value="@SearchText" @oninput="OnSearch" />
                </div>
            </div>

            @if (!FilteredItems.Any())
            {
                <div class="text-center py-5" style="color:var(--text-secondary);">
                    <i class="bi bi-images" style="font-size:3rem;"></i>
                    <p class="mt-2">هیچ نمونه کاری یافت نشد</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-bordered">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>عنوان</th>
                                <th>دسته</th>
                                <th>ترتیب</th>
                                <th>وضعیت</th>
                                <th style="width:100px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in FilteredItems)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td><strong>@item.Title</strong></td>
                                    <td><span class="badge bg-info">@item.Category</span></td>
                                    <td>@item.SortOrder</td>
                                    <td>
                                        <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                            @(item.IsActive ? "فعال" : "غیرفعال")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenEditDialog(item)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(item)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</div>

@if (ShowDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content" style="background:var(--bg-secondary);border:1px solid var(--border-color);">
                <div class="modal-header" style="border-bottom:1px solid var(--border-color);">
                    <h5 class="modal-title" style="font-size:16px;font-weight:700;">@(IsEdit ? "ویرایش نمونه کار" : "نمونه کار جدید")</h5>
                    <button type="button" class="btn-close" @onclick="CloseDialog"></button>
                </div>
                <div class="modal-body">
                    <div style="background:var(--bg-tertiary);border-radius:12px;padding:12px 16px;margin-bottom:16px;">
                        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                            <i class="bi bi-info-circle" style="color:var(--pdd-primary);"></i>
                            <strong style="font-size:0.875rem;">راهنما</strong>
                        </div>
                        <p style="margin:0;font-size:0.8125rem;color:var(--text-secondary);">اطلاعات نمونه کار را وارد کنید.</p>
                    </div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">عنوان *</label>
                            <input type="text" class="form-control" @bind="FormModel.Title" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">توضیحات</label>
                            <textarea class="form-control" rows="3" @bind="FormModel.Description"></textarea>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">دسته‌بندی</label>
                            <input type="text" class="form-control" @bind="FormModel.Category" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">ترتیب نمایش</label>
                            <input type="number" class="form-control" @bind="FormModel.SortOrder" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">تصویر URL</label>
                            <input type="text" class="form-control" @bind="FormModel.ImageUrl" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">آدرس پروژه</label>
                            <input type="text" class="form-control" @bind="FormModel.ProjectUrl" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-top:1px solid var(--border-color);">
                    <button class="btn btn-secondary" @onclick="CloseDialog">انصراف</button>
                    <button class="btn btn-primary" @onclick="SaveItem" disabled="@IsSaving">
                        @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-floppy me-1"></i>ذخیره
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<PortfolioDto> Items = new();
    List<PortfolioDto> FilteredItems = new();
    PortfolioDto FormModel = new();
    bool IsLoading = true;
    bool ShowDialog = false;
    bool IsEdit = false;
    bool IsSaving = false;
    string SearchText = "";

    protected override async Task OnInitializedAsync() => await LoadData();

    async Task LoadData()
    {
        IsLoading = true;
        Items = await Comm.GetAsync<List<PortfolioDto>>("api/portfolio/admin") ?? new();
        Filter();
        IsLoading = false;
    }

    void Filter()
    {
        var q = SearchText.Trim().ToLower();
        FilteredItems = string.IsNullOrEmpty(q)
            ? Items
            : Items.Where(x => (x.Title ?? "").ToLower().Contains(q) || (x.Category ?? "").ToLower().Contains(q)).ToList();
    }

    void OnSearch(ChangeEventArgs e) { SearchText = e.Value?.ToString() ?? ""; Filter(); }

    void OpenCreateDialog()
    {
        FormModel = new PortfolioDto { IsActive = true };
        IsEdit = false;
        ShowDialog = true;
    }

    void OpenEditDialog(PortfolioDto item)
    {
        FormModel = new PortfolioDto
        {
            Id = item.Id, Title = item.Title, Description = item.Description,
            ImageUrl = item.ImageUrl, ProjectUrl = item.ProjectUrl,
            Category = item.Category, SortOrder = item.SortOrder, IsActive = item.IsActive
        };
        IsEdit = true;
        ShowDialog = true;
    }

    void CloseDialog() => ShowDialog = false;

    async Task SaveItem()
    {
        IsSaving = true;
        try
        {
            if (IsEdit)
                await Comm.PutAsync<object>($"api/portfolio/{FormModel.Id}", FormModel);
            else
                await Comm.PostAsync<object>("api/portfolio", FormModel);
            await LoadData();
            ShowDialog = false;
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", $"خطا: {ex.Message}"); }
        finally { IsSaving = false; }
    }

    async Task DeleteItem(PortfolioDto item)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"آیا از حذف «{item.Title}» مطمئن هستید؟");
        if (!confirmed) return;
        await Comm.DeleteAsync($"api/portfolio/{item.Id}");
        await LoadData();
    }

    public class PortfolioDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string ProjectUrl { get; set; } = "";
        public string Category { get; set; } = "";
        public int SortOrder { get; set; }
        public bool IsActive { get; set; }
    }
}
