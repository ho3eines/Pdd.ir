@page "/admin/portfolio"
@attribute [AuthorizeRole("admin")]
@implements IDisposable
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IModalService Modal
@inject IAlertService Alert
@inject IJSRuntime JS

<PageTitle>@T.Text("admin_portfolio") | PDD</PageTitle>

<div class="page-enter">
    <PddTable TItem="PortfolioDto"
              Items="@Items"
              Title="@T.Text("admin_portfolio")"
              Subtitle="@(T.CurrentLanguage == "fa" ? "ایجاد و مدیریت پروژه‌ها" : "Create and manage projects")"
              IsLoading="@IsLoading"
              PageSize="10"
              CanInsert="true"
              CanEdit="true"
              CanDelete="true"
              Columns="@GetColumns()"
              SearchFilter="@Search"
              OnInsert="OpenCreate"
              OnEdit="OpenEdit"
              OnDelete="Delete"
              DeleteMessageSelector="@(x => T.Text("are_you_sure_delete"))" />
</div>

@code {
    List<PortfolioDto> Items = new();
    bool IsLoading = true;

    List<PddTableColumn<PortfolioDto>> GetColumns() => new()
    {
        new() { Title = T.Text("title"), GetValue = x => x.Title },
        new() { Title = T.Text("category"), Template = c => builder => { builder.OpenElement(0, "span"); builder.AddAttribute(1, "class", "badge bg-info"); builder.AddContent(2, c.Category); builder.CloseElement(); }},
        new() { Title = T.Text("sort_order"), GetValue = x => x.SortOrder.ToString() },
        new() { Title = T.Text("status"), Template = c => builder => { builder.OpenElement(0, "span"); builder.AddAttribute(1, "class", $"badge {(c.IsActive ? "bg-success" : "bg-secondary")}"); builder.AddContent(2, c.IsActive ? T.Text("active") : T.Text("inactive")); builder.CloseElement(); }}
    };

    protected override async Task OnInitializedAsync() { T.OnLanguageChanged += Refresh; await Load(); }
    void Refresh() => InvokeAsync(StateHasChanged);
    async Task Load() { IsLoading = true; Items = await Comm.GetAsync<List<PortfolioDto>>("api/portfolio/admin") ?? new(); IsLoading = false; }
    bool Search(PortfolioDto x, string q) => (x.Title ?? "").ToLower().Contains(q) || (x.Category ?? "").ToLower().Contains(q);
    async Task OpenCreate() => await Modal.Show<PortfolioDialog>(T.Text("portfolio_new"));
    async Task OpenEdit(PortfolioDto x) => await Modal.Show<PortfolioDialog>(T.Text("portfolio_edit"), new Dictionary<string, object> { { "Id", x.Id } });
    async Task Delete(PortfolioDto x) { await Comm.DeleteAsync($"api/portfolio/{x.Id}"); await Alert.ShowSuccessAsync(T.Text("success"), T.Text("deleted_successfully")); await Load(); }
    public void Dispose() { T.OnLanguageChanged -= Refresh; }
    public class PortfolioDto { public int Id { get; set; } public string Title { get; set; } = ""; public string Description { get; set; } = ""; public string Category { get; set; } = ""; public int SortOrder { get; set; } public bool IsActive { get; set; } public string ImageUrl { get; set; } = ""; public string ProjectUrl { get; set; } = ""; }
}
