@page "/admin/products"
@attribute [AuthorizeRole("admin")]
@implements IDisposable
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IModalService Modal
@inject IAlertService Alert
@inject IJSRuntime JS

<PageTitle>@T.Text("admin_products") | PDD</PageTitle>

<div class="page-enter">
    <PddTable TItem="ProductDto"
              Items="@Items"
              Title="@T.Text("admin_products")"
              Subtitle="@(T.CurrentLanguage == "fa" ? "ایجاد، ویرایش و حذف محصولات" : "Create, edit and delete products")"
              IsLoading="@IsLoading"
              PageSize="10"
              CanInsert="true"
              CanEdit="true"
              CanDelete="true"
              Columns="@GetColumns()"
              SearchFilter="@Search"
              OnInsert="OpenCreate"
              OnEdit="OpenEdit"
              OnDelete="Delete"
              DeleteMessageSelector="@(_ => T.Text("are_you_sure_delete"))" />
</div>

@code {
    List<ProductDto> Items = new();
    bool IsLoading = true;

    List<PddTableColumn<ProductDto>> GetColumns() => new()
    {
        new() { Title = T.Text("title"), GetValue = x => x.Title },
        new() { Title = T.Text("subtitle"), GetValue = x => x.Subtitle },
        new() { Title = T.Text("category"), Template = c => builder => { builder.OpenElement(0, "span"); builder.AddAttribute(1, "class", "badge bg-info"); builder.AddContent(2, c.Category); builder.CloseElement(); }},
        new() { Title = T.Text("status"), Template = c => builder => { builder.OpenElement(0, "span"); builder.AddAttribute(1, "class", $"badge {(c.IsActive ? "bg-success" : "bg-secondary")}"); builder.AddContent(2, c.IsActive ? T.Text("active") : T.Text("inactive")); builder.CloseElement(); }}
    };

    protected override async Task OnInitializedAsync() { T.OnLanguageChanged += Refresh; await Load(); }
    void Refresh() => InvokeAsync(StateHasChanged);
    async Task Load() { IsLoading = true; Items = await Comm.GetAsync<List<ProductDto>>("api/product") ?? new(); IsLoading = false; }
    bool Search(ProductDto x, string q) => (x.Title ?? "").ToLower().Contains(q) || (x.Category ?? "").ToLower().Contains(q);
    async Task OpenCreate() => await Modal.Show<ProductDialog>(T.Text("product_new"));
    async Task OpenEdit(ProductDto x) => await Modal.Show<ProductDialog>(T.Text("product_edit"), new Dictionary<string, object> { { "Id", x.Id } });
    async Task Delete(ProductDto x) { try { await Comm.DeleteAsync($"api/product/{x.Id}"); await Alert.ShowSuccessAsync(T.Text("success"), T.Text("deleted_successfully")); await Load(); } catch (Exception) { await Alert.ShowErrorAsync(T.Text("error"), T.Text("operation_failed")); } }
    public void Dispose() { T.OnLanguageChanged -= Refresh; }
    public class ProductDto { public int Id { get; set; } public string Title { get; set; } = ""; public string Subtitle { get; set; } = ""; public string Description { get; set; } = ""; public string Category { get; set; } = ""; public int SortOrder { get; set; } public bool IsActive { get; set; } public string ImageUrl { get; set; } = ""; }
}
