@page "/admin/homeslides"
@attribute [AuthorizeRole("admin")]
@implements IDisposable
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IModalService Modal
@inject IAlertService Alert
@inject IFileUploadService FileUpload

<PageTitle>@T.Text("home_slide_management") | PDD</PageTitle>

<div class="page-enter">
    <PddTable TItem="HomeSlideDto"
              Items="@Items"
              Title="@T.Text("home_slide_management")"
              Subtitle="@T.Text("home_slide_subtitle")"
              IsLoading="@IsLoading"
              PageSize="10"
              CanInsert="true"
              CanEdit="true"
              CanDelete="true"
              Columns="@GetColumns()"
              SearchFilter="@Search"
              OnInsert="OpenCreate"
              OnEdit="OpenEdit"
              OnDelete="Delete"
              DeleteMessageSelector="@(x => T.Text("are_you_sure_delete"))" />
</div>

@code {
    List<HomeSlideDto> Items = new();
    bool IsLoading = true;
    Dictionary<int, string> _imageCache = new();

    protected override async Task OnInitializedAsync()
    {
        T.OnLanguageChanged += Refresh;
        await LoadData();
    }

    async Task LoadData()
    {
        IsLoading = true;
        Items = await Comm.GetAsync<List<HomeSlideDto>>("api/homeslide/admin") ?? new();

        var imageTasks = Items
            .Where(x => !string.IsNullOrEmpty(x.ImageUrl))
            .Select(async item =>
            {
                try
                {
                    var file = await FileUpload.GetFileAsync(item.ImageUrl);
                    if (file != null)
                        _imageCache[item.Id] = $"data:{file.contentType};base64,{file.base64}";
                }
                catch { }
            });
        await Task.WhenAll(imageTasks);

        IsLoading = false;
        StateHasChanged();
    }

    List<PddTableColumn<HomeSlideDto>> GetColumns() => new()
    {
        new() { Title = "#", GetValue = x => x.Id.ToString() },
        new() { Title = T.Text("badge_fa"), GetValue = x => x.BadgeFa },
        new() { Title = T.Text("title_fa"), GetValue = x => x.TitleFa },
        new() { Title = T.Text("description_fa"), GetValue = x => x.DescFa?.Length > 50 ? x.DescFa[..50] + "..." : x.DescFa },
        new() { Title = T.Text("image"), Template = c => builder =>
        {
            if (_imageCache.TryGetValue(c.Id, out var imageUrl))
            {
                builder.OpenElement(0, "img");
                builder.AddAttribute(1, "src", imageUrl);
                builder.AddAttribute(2, "style", "width:40px;height:40px;object-fit:cover;border-radius:8px;");
                builder.CloseElement();
            }
            else
            {
                builder.OpenElement(0, "i");
                builder.AddAttribute(1, "class", "bi bi-image text-muted");
                builder.CloseElement();
            }
        }},
        new() { Title = T.Text("sort_order"), GetValue = x => x.SortOrder.ToString() },
        new() { Title = T.Text("status"), Template = c => builder =>
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", $"badge {(c.IsActive ? "bg-success" : "bg-secondary")}");
            builder.AddContent(2, c.IsActive ? T.Text("active") : T.Text("inactive"));
            builder.CloseElement();
        }}
    };

    bool Search(HomeSlideDto x, string q) =>
        (x.BadgeFa ?? "").ToLower().Contains(q) ||
        (x.TitleFa ?? "").ToLower().Contains(q);

    async Task OpenCreate()
    {
        await Modal.Show<HomeSlideDialog>(T.Text("new_slide"));
        await LoadData();
    }

    async Task OpenEdit(HomeSlideDto item)
    {
        await Modal.Show<HomeSlideDialog>(T.Text("edit_slide"), new Dictionary<string, object> { { "Id", item.Id } });
        await LoadData();
    }

    async Task Delete(HomeSlideDto item)
    {
        try
        {
            var result = await Comm.DeleteAsync($"api/homeslide/{item.Id}");
            if (result)
            {
                await Alert.ShowSuccessAsync(T.Text("success"), T.Text("deleted_successfully"));
                await LoadData();
            }
            else
            {
                await Alert.ShowErrorAsync(T.Text("error"), T.Text("operation_failed"));
            }
        }
        catch { await Alert.ShowErrorAsync(T.Text("error"), T.Text("operation_failed")); }
    }

    void Refresh() => InvokeAsync(StateHasChanged);
    public void Dispose() => T.OnLanguageChanged -= Refresh;
}
