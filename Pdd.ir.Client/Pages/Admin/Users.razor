@page "/admin/users"
@inject ITranslateService T

<PageTitle>@T.Text("admin_users") | PDD</PageTitle>

<div class="d-flex align-items-center justify-between mb-4" style="padding-top:24px;">
    <div>
        <h1 style="font-size:28px;font-weight:700;">@T.Text("admin_users")</h1>
        <p class="text-muted" style="font-size:14px;">@(T.CurrentLanguage == "fa" ? "مشاهده و مدیریت کاربران سیستم" : "View and manage system users")</p>
    </div>
</div>

<section class="section" style="padding-top:0;">
    <div class="container">
        <div class="card">
            <div style="overflow-x:auto;">
                <table style="width:100%;border-collapse:collapse;">
                    <thead>
                        <tr style="border-bottom:1px solid var(--pdd-border);">
                            <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">#</th>
                            <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "نام کاربری" : "Username")</th>
                            <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "نام کامل" : "Full Name")</th>
                            <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "ایمیل" : "Email")</th>
                            <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "نقش" : "Role")</th>
                            <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "وضعیت" : "Status")</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr style="border-bottom:1px solid var(--pdd-border);">
                            <td style="padding:12px;font-size:14px;">1</td>
                            <td style="padding:12px;font-size:14px;">admin</td>
                            <td style="padding:12px;font-size:14px;">@(T.CurrentLanguage == "fa" ? "مدیر سیستم" : "System Admin")</td>
                            <td style="padding:12px;font-size:14px;">admin@pdd.ir</td>
                            <td style="padding:12px;"><span style="padding:4px 10px;background:rgba(255,176,32,0.15);color:var(--pdd-secondary);border-radius:100px;font-size:12px;font-weight:600;">Admin</span></td>
                            <td style="padding:12px;"><span style="padding:4px 10px;background:rgba(34,197,94,0.15);color:#22c55e;border-radius:100px;font-size:12px;font-weight:600;">@(T.CurrentLanguage == "fa" ? "فعال" : "Active")</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
