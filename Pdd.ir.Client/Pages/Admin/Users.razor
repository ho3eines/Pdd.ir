@page "/admin/users"
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>@T.Text("admin_users") | PDD</PageTitle>

<div class="page-enter">
    <div class="d-flex align-items-center justify-content-between mb-4" style="padding-top:24px;">
        <div>
            <h1 style="font-size:28px;font-weight:700;">@(T.CurrentLanguage == "fa" ? "مدیریت کاربران" : "User Management")</h1>
            <p class="text-muted" style="font-size:14px;">@(T.CurrentLanguage == "fa" ? "تعریف، ویرایش و مدیریت دسترسی کاربران" : "Create, edit and manage user access")</p>
        </div>
        <button class="btn btn-primary" @onclick="OpenCreateDialog">
            <i class="bi bi-plus-lg me-1"></i>@(T.CurrentLanguage == "fa" ? "کاربر جدید" : "New User")
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="skeleton skeleton-card" style="height:400px;"></div>
    }
    else
    {
        <div class="glass-card fade-slide-in" style="padding:20px;">
            <div class="d-flex align-items-center gap-2 mb-3">
                <div class="flex-grow-1">
                    <input type="text" class="form-control" placeholder="@(T.CurrentLanguage == "fa" ? "جستجوی نام کاربری، نام، ایمیل..." : "Search username, name, email...")"
                           value="@SearchText" @oninput="OnSearch" />
                </div>
                <span class="text-muted" style="font-size:12px;">@FilteredUsers.Count رکورد</span>
            </div>

            @if (!FilteredUsers.Any())
            {
                <div class="text-center py-5" style="color:var(--text-tertiary);">
                    <i class="bi bi-people" style="font-size:3rem;"></i>
                    <p class="mt-2">@(T.CurrentLanguage == "fa" ? "هیچ کاربری یافت نشد" : "No users found")</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-bordered">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>@(T.CurrentLanguage == "fa" ? "نام کاربری" : "Username")</th>
                                <th>@(T.CurrentLanguage == "fa" ? "نام کامل" : "Full Name")</th>
                                <th>@(T.CurrentLanguage == "fa" ? "ایمیل" : "Email")</th>
                                <th>@(T.CurrentLanguage == "fa" ? "نقش" : "Role")</th>
                                <th>@(T.CurrentLanguage == "fa" ? "وضعیت" : "Status")</th>
                                <th style="width:140px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in FilteredUsers)
                            {
                                <tr>
                                    <td>@u.Id</td>
                                    <td><strong>@u.Username</strong></td>
                                    <td>@u.FullName</td>
                                    <td>@u.Email</td>
                                    <td>
                                        <span class="badge @(u.Role == "admin" ? "bg-warning text-dark" : "bg-info")">@u.Role</span>
                                    </td>
                                    <td>
                                        <span class="badge @(u.IsActive ? "bg-success" : "bg-secondary")">
                                            @(u.IsActive ? (T.CurrentLanguage == "fa" ? "فعال" : "Active") : (T.CurrentLanguage == "fa" ? "غیرفعال" : "Inactive"))
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenEditDialog(u)" title="ویرایش">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm @(u.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                    @onclick="() => ToggleActive(u)" title="@(u.IsActive ? "غیرفعال‌سازی" : "فعال‌سازی")">
                                                <i class="bi @(u.IsActive ? "bi-toggle-off" : "bi-toggle-on")"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-info" @onclick="() => OpenPasswordDialog(u)" title="تغییر رمز">
                                                <i class="bi bi-key"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUser(u)" title="حذف">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
</div>

@if (ShowDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background:var(--bg-secondary);border:1px solid var(--border-color);">
                <div class="modal-header" style="border-bottom:1px solid var(--border-color);">
                    <h5 class="modal-title" style="font-size:16px;font-weight:700;">
                        @(DialogMode == "password" ? "تغییر رمز عبور" : (IsEdit ? "ویرایش کاربر" : "کاربر جدید"))
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseDialog"></button>
                </div>
                <div class="modal-body">
                    @if (DialogMode == "password")
                    {
                        <div class="mb-3">
                            <label class="form-label">رمز عبور جدید *</label>
                            <input type="password" class="form-control" @bind="PasswordModel" />
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @if (!IsEdit)
                            {
                                <div class="col-12 col-md-6">
                                    <label class="form-label">نام کاربری *</label>
                                    <input type="text" class="form-control" @bind="CreateUsername" />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">رمز عبور *</label>
                                    <input type="password" class="form-control" @bind="CreatePassword" />
                                </div>
                            }
                            <div class="col-12 col-md-6">
                                <label class="form-label">نام کامل</label>
                                <input type="text" class="form-control" @bind="FormModel.FullName" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">ایمیل</label>
                                <input type="email" class="form-control" @bind="FormModel.Email" />
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label">نقش</label>
                                <select class="form-select" @bind="FormModel.Role">
                                    <option value="User">User</option>
                                    <option value="admin">Admin</option>
                                    <option value="manager">Manager</option>
                                </select>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer" style="border-top:1px solid var(--border-color);">
                    <button class="btn btn-secondary" @onclick="CloseDialog">انصراف</button>
                    <button class="btn btn-primary" @onclick="SaveUser" disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-floppy me-1"></i>ذخیره
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<UserDto> UserList = new();
    List<UserDto> FilteredUsers = new();
    UserDto FormModel = new();
    string PasswordModel = "";
    string CreateUsername = "";
    string CreatePassword = "";
    bool IsLoading = true;
    bool ShowDialog = false;
    bool IsEdit = false;
    bool IsSaving = false;
    string DialogMode = "form";
    string SearchText = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    async Task LoadUsers()
    {
        IsLoading = true;
        UserList = await Comm.GetAsync<List<UserDto>>("api/user") ?? new();
        Filter();
        IsLoading = false;
    }

    void Filter()
    {
        var q = SearchText.Trim().ToLower();
        FilteredUsers = string.IsNullOrEmpty(q)
            ? UserList
            : UserList.Where(u => (u.Username ?? "").ToLower().Contains(q)
                             || (u.FullName ?? "").ToLower().Contains(q)
                             || (u.Email ?? "").ToLower().Contains(q)).ToList();
    }

    void OnSearch(ChangeEventArgs e)
    {
        SearchText = e.Value?.ToString() ?? "";
        Filter();
    }

    void OpenCreateDialog()
    {
        FormModel = new UserDto { Role = "User" };
        CreateUsername = "";
        CreatePassword = "";
        IsEdit = false;
        DialogMode = "form";
        ShowDialog = true;
    }

    void OpenEditDialog(UserDto user)
    {
        FormModel = new UserDto
        {
            Id = user.Id,
            Username = user.Username,
            Email = user.Email,
            FullName = user.FullName,
            Role = user.Role
        };
        IsEdit = true;
        DialogMode = "form";
        ShowDialog = true;
    }

    void OpenPasswordDialog(UserDto user)
    {
        FormModel = user;
        PasswordModel = "";
        DialogMode = "password";
        ShowDialog = true;
    }

    void CloseDialog()
    {
        ShowDialog = false;
    }

    async Task SaveUser()
    {
        IsSaving = true;

        try
        {
            if (DialogMode == "password")
            {
                if (string.IsNullOrWhiteSpace(PasswordModel))
                {
                    await JS.InvokeVoidAsync("alert", "رمز عبور را وارد کنید");
                    return;
                }
                await Comm.PostAsync<object>($"api/user/{FormModel.Id}/password", new { Password = PasswordModel });
            }
            else if (IsEdit)
            {
                await Comm.PutAsync<object>($"api/user/{FormModel.Id}", new
                {
                    FormModel.Email,
                    FormModel.FullName,
                    FormModel.Role
                });
            }
            else
            {
                if (string.IsNullOrWhiteSpace(CreateUsername))
                {
                    await JS.InvokeVoidAsync("alert", "نام کاربری الزامی است");
                    return;
                }
                await Comm.PostAsync<object>("api/user", new
                {
                    Username = CreateUsername,
                    Password = CreatePassword,
                    FormModel.Email,
                    FormModel.FullName,
                    FormModel.Role
                });
            }

            await LoadUsers();
            ShowDialog = false;
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"خطا: {ex.Message}");
        }
        finally
        {
            IsSaving = false;
        }
    }

    async Task ToggleActive(UserDto user)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            user.IsActive
                ? $"آیا از غیرفعال‌سازی «{user.Username}» مطمئن هستید؟"
                : $"آیا از فعال‌سازی «{user.Username}» مطمئن هستید؟");

        if (!confirmed) return;

        await Comm.PutAsync<object>($"api/user/{user.Id}/toggle", new { });
        await LoadUsers();
    }

    async Task DeleteUser(UserDto user)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"آیا از حذف «{user.Username}» مطمئن هستید؟");
        if (!confirmed) return;

        await Comm.DeleteAsync($"api/user/{user.Id}");
        await LoadUsers();
    }

    public void Dispose() { }
}
