@page "/admin/events"
@attribute [AuthorizeRole("admin")]
@implements IDisposable
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IModalService Modal
@inject IAlertService Alert
@inject IFileUploadService FileUpload

<PageTitle>@T.Text("event_management") | PDD</PageTitle>

<div class="page-enter">
    <PddTable TItem="EventDto"
              Items="@Items"
              Title="@T.Text("event_management")"
              Subtitle="@T.Text("event_subtitle")"
              IsLoading="@IsLoading"
              PageSize="10"
              CanInsert="true"
              CanEdit="true"
              CanDelete="true"
              Columns="@GetColumns()"
              SearchFilter="@Search"
              OnInsert="OpenCreate"
              OnEdit="OpenEdit"
              OnDelete="Delete"
              DeleteMessageSelector="@(x => T.Text("are_you_sure_delete"))" />
</div>

@code {
    List<EventDto> Items = new();
    bool IsLoading = true;
    Dictionary<int, string> _imageCache = new();

    protected override async Task OnInitializedAsync()
    {
        T.OnLanguageChanged += Refresh;
        await LoadData();
    }

    async Task LoadData()
    {
        IsLoading = true;
        Items = await Comm.GetAsync<List<EventDto>>("api/event") ?? new();
        
        var imageTasks = Items
            .Where(x => !string.IsNullOrEmpty(x.ImageUrl))
            .Select(async item =>
            {
                try
                {
                    var file = await FileUpload.GetFileAsync(item.ImageUrl);
                    if (file != null)
                    {
                        _imageCache[item.Id] = $"data:{file.contentType};base64,{file.base64}";
                    }
                }
                catch { }
            });
        
        await Task.WhenAll(imageTasks);
        
        IsLoading = false;
        StateHasChanged();
    }

    List<PddTableColumn<EventDto>> GetColumns() => new()
    {
        new() { Title = "#", GetValue = x => x.Id.ToString() },
        new() { Title = T.Text("title_fa"), GetValue = x => x.Title },
        new() { Title = T.Text("title_en"), GetValue = x => x.TitleEn },
        new() { Title = T.Text("image"), Template = c => builder =>
        {
            if (_imageCache.TryGetValue(c.Id, out var imageUrl))
            {
                builder.OpenElement(0, "img");
                builder.AddAttribute(1, "src", imageUrl);
                builder.AddAttribute(2, "style", "width:40px;height:40px;object-fit:cover;border-radius:8px;");
                builder.AddAttribute(3, "alt", c.Title);
                builder.CloseElement();
            }
            else
            {
                builder.OpenElement(0, "i");
                builder.AddAttribute(1, "class", "bi bi-calendar-event text-muted");
                builder.CloseElement();
            }
        }},
        new() { Title = T.Text("location"), GetValue = x => x.Location },
        new() { Title = T.Text("event_date"), GetValue = x => DateHelper.ToShamsi(x.EventDate) },
        new() { Title = T.Text("sort_order"), GetValue = x => x.SortOrder.ToString() },
        new() { Title = T.Text("status"), Template = c => builder =>
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", $"badge {(c.IsActive ? "bg-success" : "bg-secondary")}");
            builder.AddContent(2, c.IsActive ? T.Text("active") : T.Text("inactive"));
            builder.CloseElement();
        }}
    };

    bool Search(EventDto x, string q) =>
        (x.Title ?? "").ToLower().Contains(q) ||
        (x.TitleEn ?? "").ToLower().Contains(q) ||
        (x.Location ?? "").ToLower().Contains(q);

    async Task OpenCreate()
    {
        await Modal.Show<EventDialog>(T.Text("new_event"));
        await LoadData();
    }

    async Task OpenEdit(EventDto item)
    {
        await Modal.Show<EventDialog>(T.Text("edit_event"), new Dictionary<string, object> { { "Id", item.Id } });
        await LoadData();
    }

    async Task Delete(EventDto item)
    {
        try
        {
            var result = await Comm.DeleteAsync($"api/event/{item.Id}");
            if (result)
            {
                await Alert.ShowSuccessAsync(T.Text("success"), T.Text("deleted_successfully"));
                await Task.Delay(100);
                await LoadData();
                StateHasChanged();
            }
            else
            {
                await Alert.ShowErrorAsync(T.Text("error"), T.Text("operation_failed"));
            }
        }
        catch
        {
            await Alert.ShowErrorAsync(T.Text("error"), T.Text("operation_failed"));
        }
    }

    void Refresh() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        T.OnLanguageChanged -= Refresh;
    }
}
