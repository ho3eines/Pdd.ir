@page "/admin/blog"
@implements IDisposable
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IModalService Modal
@inject IAlertService Alert
@inject IJSRuntime JS

<PageTitle>@T.Text("admin_blog") | PDD</PageTitle>

<div class="page-enter">
    <PddTable TItem="BlogDto"
              Items="@Items"
              Title="@T.Text("admin_blog")"
              Subtitle="@(T.CurrentLanguage == "fa" ? "ایجاد و مدیریت مقالات" : "Create and manage articles")"
              IsLoading="@IsLoading"
              PageSize="10"
              CanInsert="true"
              CanEdit="true"
              CanDelete="true"
              Columns="@_columns"
              SearchFilter="@Search"
              OnInsert="OpenCreate"
              OnEdit="OpenEdit"
              OnDelete="Delete"
              DeleteMessageSelector="@(x => T.Text("are_you_sure_delete"))" />
</div>

@code {
    List<BlogDto> Items = new();
    bool IsLoading = true;
    List<PddTableColumn<BlogDto>> _columns = new()
    {
        new() { Title = "عنوان", GetValue = x => x.Title },
        new() { Title = "نویسنده", GetValue = x => x.Author },
        new() { Title = "بازدید", GetValue = x => x.ViewCount.ToString() },
        new() { Title = "وضعیت", Template = c => builder => { builder.OpenElement(0, "span"); builder.AddAttribute(1, "class", $"badge {(c.IsPublished ? "bg-success" : "bg-secondary")}"); builder.AddContent(2, c.IsPublished ? "منتشر شده" : "پیش‌نویس"); builder.CloseElement(); }}
    };
    protected override async Task OnInitializedAsync() { T.OnLanguageChanged += Refresh; await Load(); }
    void Refresh() => InvokeAsync(StateHasChanged);
    async Task Load() { IsLoading = true; Items = await Comm.GetAsync<List<BlogDto>>("api/blog/admin") ?? new(); IsLoading = false; }
    bool Search(BlogDto x, string q) => (x.Title ?? "").ToLower().Contains(q) || (x.Author ?? "").ToLower().Contains(q);
    async Task OpenCreate() => await Modal.Show<BlogDialog>(T.Text("blog_new"));
    async Task OpenEdit(BlogDto x) => await Modal.Show<BlogDialog>(T.Text("blog_edit"), new Dictionary<string, object> { { "Id", x.Id } });
    async Task Delete(BlogDto x) { await Comm.DeleteAsync($"api/blog/{x.Id}"); await Alert.ShowSuccessAsync(T.Text("success"), T.Text("deleted_successfully")); await Load(); }
    public void Dispose() { T.OnLanguageChanged -= Refresh; }
    public class BlogDto { public int Id { get; set; } public string Title { get; set; } = ""; public string Slug { get; set; } = ""; public string Summary { get; set; } = ""; public string Content { get; set; } = ""; public string Author { get; set; } = ""; public bool IsPublished { get; set; } public int ViewCount { get; set; } }
}
