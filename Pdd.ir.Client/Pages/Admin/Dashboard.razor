@page "/admin"
@inject HttpClient Http
@inject ITranslateService T

<PageTitle>@T.Text("dashboard") | PDD</PageTitle>

<div class="section-header" style="padding-top:24px;">
    <h1 class="section-title" style="font-size:28px;">@T.Text("dashboard")</h1>
    <p class="section-subtitle" style="font-size:14px;">@(T.CurrentLanguage == "fa" ? "مدیریت محتوا و محصولات" : "Content and product management")</p>
</div>

<section class="section" style="padding-top:0;">
    <div class="container">
        <div class="grid-4 mb-4">
            <div class="stat-card">
                <i class="bi bi-box-seam" style="font-size:24px;color:var(--pdd-primary);"></i>
                <div class="stat-number" style="font-size:32px;">@(_productCount)</div>
                <div class="stat-label">@T.Text("products")</div>
            </div>
            <div class="stat-card">
                <i class="bi bi-envelope" style="font-size:24px;color:var(--pdd-cyan);"></i>
                <div class="stat-number" style="font-size:32px;">@(_messageCount)</div>
                <div class="stat-label">@T.Text("admin_messages")</div>
            </div>
            <div class="stat-card">
                <i class="bi bi-envelope-exclamation" style="font-size:24px;color:var(--pdd-secondary);"></i>
                <div class="stat-number" style="font-size:32px;">@(_unreadCount)</div>
                <div class="stat-label">@(T.CurrentLanguage == "fa" ? "خوانده نشده" : "Unread")</div>
            </div>
            <div class="stat-card">
                <i class="bi bi-file-earmark-text" style="font-size:24px;color:var(--pdd-pink);"></i>
                <div class="stat-number" style="font-size:32px;">@(_pageCount)</div>
                <div class="stat-label">@(T.CurrentLanguage == "fa" ? "صفحات" : "Pages")</div>
            </div>
        </div>

        <div class="grid-2">
            <div class="card">
                <h3 style="margin-bottom:16px;"><i class="bi bi-box-seam me-2"></i>@T.Text("admin_products")</h3>
                @if (_products != null)
                {
                    <div style="overflow-x:auto;">
                        <table class="table table-hover" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>@(T.CurrentLanguage == "fa" ? "عنوان" : "Title")</th>
                                    <th>@(T.CurrentLanguage == "fa" ? "دسته‌بندی" : "Category")</th>
                                    <th>@(T.CurrentLanguage == "fa" ? "عملیات" : "Actions")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in _products)
                                {
                                    <tr>
                                        <td>@p.Title</td>
                                        <td>@p.Category</td>
                                        <td>
                                            <button class="btn btn-sm btn-glass" @onclick="() => EditProduct(p)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
            <div class="card">
                <h3 style="margin-bottom:16px;"><i class="bi bi-envelope me-2"></i>@(T.CurrentLanguage == "fa" ? "پیام‌های اخیر" : "Recent Messages")</h3>
                @if (_messages != null)
                {
                    @foreach (var msg in _messages.Take(5))
                    {
                        <div style="padding:12px;border-bottom:1px solid var(--pdd-border);@(msg.IsRead ? "" : "background:var(--pdd-primary-glow);")">
                            <div class="d-flex justify-between align-center">
                                <strong style="font-size:14px;">@msg.Name</strong>
                                <small class="text-muted">@msg.CreatedAt.ToString("yyyy/MM/dd")</small>
                            </div>
                            <p style="font-size:13px;margin-top:4px;">@msg.Subject</p>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</section>

@code {
    private int _productCount;
    private int _messageCount;
    private int _unreadCount;
    private int _pageCount;
    private List<ProductDto>? _products;
    private List<ContactDto>? _messages;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var productsResponse = await Http.GetFromJsonAsync<ApiResponse<List<ProductDto>>>("api/product");
            _products = productsResponse?.Data;
            _productCount = _products?.Count ?? 0;

            var messagesResponse = await Http.GetFromJsonAsync<ApiResponse<List<ContactDto>>>("api/contact");
            _messages = messagesResponse?.Data;
            _messageCount = _messages?.Count ?? 0;
            _unreadCount = _messages?.Count(m => !m.IsRead) ?? 0;

            var pagesResponse = await Http.GetFromJsonAsync<ApiResponse<List<object>>>("api/page");
            _pageCount = pagesResponse?.Data?.Count ?? 0;
        }
        catch { }
    }

    private void EditProduct(ProductDto product)
    {
    }

    public class ProductDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Category { get; set; } = "";
    }

    public class ContactDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Subject { get; set; } = "";
        public bool IsRead { get; set; }
        public DateTime CreatedAt { get; set; }
    }

    public class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public T? Data { get; set; }
    }
}
