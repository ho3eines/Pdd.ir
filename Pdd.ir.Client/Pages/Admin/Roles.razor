@page "/admin/roles"
@implements IDisposable
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IAppStateService AppState
@inject IModalService Modal
@inject IAlertService Alert
@inject IJSRuntime JS

<PageTitle>@(T.CurrentLanguage == "fa" ? "مدیریت نقش‌ها" : "Roles") | PDD</PageTitle>

<div class="page-enter">
    <PddTable TItem="RoleDto"
              Items="@Items"
              Title="@(T.CurrentLanguage == "fa" ? "مدیریت نقش‌ها و دسترسی‌ها" : "Roles & Permissions")"
              Subtitle="@(T.CurrentLanguage == "fa" ? "تعریف نقش‌ها و مدیریت دسترسی‌های هر نقش" : "Define roles and manage their permissions")"
              IsLoading="@IsLoading"
              PageSize="10"
              CanInsert="true"
              CanEdit="true"
              CanDelete="true"
              Columns="@_columns"
              SearchFilter="@Search"
              OnInsert="OpenCreate"
              OnEdit="OpenEdit"
              OnDelete="Delete"
              DeleteMessageSelector="@(x => T.Text("are_you_sure_delete"))" />
</div>

@code {
    List<RoleDto> Items = new();
    bool IsLoading = true;
    List<PddTableColumn<RoleDto>> _columns = new()
    {
        new() { Title = "نام نقش", GetValue = x => x.Name },
        new() { Title = "توضیحات", GetValue = x => x.Description }
    };
    protected override async Task OnInitializedAsync() { AppState.OnStateChanged += Refresh; await Load(); }
    void Refresh() => InvokeAsync(StateHasChanged);
    async Task Load() { IsLoading = true; Items = await Comm.GetAsync<List<RoleDto>>("api/role") ?? new(); IsLoading = false; }
    bool Search(RoleDto x, string q) => (x.Name ?? "").ToLower().Contains(q) || (x.Description ?? "").ToLower().Contains(q);
    async Task OpenCreate() => await Modal.Show<RoleDialog>(T.Text("role_new"));
    async Task OpenEdit(RoleDto x) => await Modal.Show<RoleDialog>(T.Text("role_edit"), new Dictionary<string, object> { { "Id", x.Id } });
    async Task Delete(RoleDto x) { await Comm.DeleteAsync($"api/role/{x.Id}"); await Alert.ShowSuccessAsync(T.Text("success"), T.Text("deleted_successfully")); await Load(); }
    public void Dispose() { AppState.OnStateChanged -= Refresh; }
    public class RoleDto { public int Id { get; set; } public string Name { get; set; } = ""; public string Description { get; set; } = ""; }
}
