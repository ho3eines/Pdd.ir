@page "/admin/roles"
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IJSRuntime JS

<PageTitle>مدیریت نقش‌ها | PDD</PageTitle>

<div class="page-enter">
    <div class="d-flex align-items-center justify-content-between mb-4" style="padding-top:24px;">
        <div>
            <h1 style="font-size:28px;font-weight:700;">@(T.CurrentLanguage == "fa" ? "مدیریت نقش‌ها و دسترسی‌ها" : "Roles & Permissions")</h1>
            <p class="text-muted" style="font-size:14px;">@(T.CurrentLanguage == "fa" ? "تعریف نقش‌ها و مدیریت دسترسی‌های هر نقش" : "Define roles and manage their permissions")</p>
        </div>
        <button class="btn btn-primary" @onclick="OpenCreateDialog">
            <i class="bi bi-plus-lg me-1"></i>@(T.CurrentLanguage == "fa" ? "نقش جدید" : "New Role")
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="skeleton skeleton-card" style="height:400px;"></div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var role in RoleList)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="glass-card hover-lift fade-slide-in p-4" style="height:100%;">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,var(--pdd-primary),var(--pdd-pink));display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-shield-lock" style="color:#fff;font-size:18px;"></i>
                                </div>
                                <div>
                                    <strong style="font-size:14px;">@role.Name</strong>
                                    <div style="font-size:11px;color:var(--text-secondary);">@role.Description</div>
                                </div>
                            </div>
                        </div>

                        <div style="margin-top:auto;padding-top:12px;border-top:1px solid var(--border-color);">
                            <button class="btn btn-sm btn-outline-primary w-100 mb-2" @onclick="() => OpenEditDialog(role)">
                                <i class="bi bi-pencil me-1"></i>ویرایش
                            </button>
                            <button class="btn btn-sm btn-outline-danger w-100" @onclick="() => DeleteRole(role)">
                                <i class="bi bi-trash me-1"></i>حذف
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (ShowDialog)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content" style="background:var(--bg-secondary);border:1px solid var(--border-color);">
                <div class="modal-header" style="border-bottom:1px solid var(--border-color);">
                    <h5 class="modal-title" style="font-size:16px;font-weight:700;">@(IsEdit ? "ویرایش نقش" : "نقش جدید")</h5>
                    <button type="button" class="btn-close" @onclick="CloseDialog"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3 mb-4">
                        <div class="col-12 col-md-6">
                            <label class="form-label">نام نقش *</label>
                            <input type="text" class="form-control" @bind="FormName" placeholder="مثال: admin, editor, viewer" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">توضیحات</label>
                            <input type="text" class="form-control" @bind="FormDescription" placeholder="توضیح کوتاه درباره این نقش" />
                        </div>
                    </div>

                    <label class="form-label" style="font-weight:700;">دسترسی‌ها</label>

                    @if (!AllPermissions.Any())
                    {
                        <div class="text-center py-3 text-muted">هیچ دسترسی‌ای یافت نشد</div>
                    }
                    else
                    {
                        var categories = AllPermissions.Select(p => p.Category).Distinct().ToList();
                        @foreach (var cat in categories)
                        {
                            <div class="mb-3">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span style="font-size:12px;font-weight:700;color:var(--pdd-primary);text-transform:uppercase;">@cat</span>
                                    <button class="btn btn-sm btn-outline-secondary" style="font-size:10px;padding:2px 8px;"
                                            @onclick="() => ToggleCategory(cat)">
                                        @(IsCategorySelected(cat) ? "لغو انتخاب" : "انتخاب همه")
                                    </button>
                                </div>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var perm in AllPermissions.Where(p => p.Category == cat))
                                    {
                                        <label class="d-flex align-items-center gap-1" style="font-size:12px;cursor:pointer;padding:4px 10px;border-radius:8px;border:1px solid var(--border-color);background:var(--bg-tertiary);">
                                            <input type="checkbox" checked="@SelectedPermissionIds.Contains(perm.Id)"
                                                   @onchange="() => TogglePermission(perm.Id)" />
                                            <span>@perm.Label</span>
                                        </label>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer" style="border-top:1px solid var(--border-color);">
                    <button class="btn btn-secondary" @onclick="CloseDialog">انصراف</button>
                    <button class="btn btn-primary" @onclick="SaveRole" disabled="@IsSaving">
                        @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-floppy me-1"></i>ذخیره
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<RoleDto> RoleList = new();
    List<PermissionDto> AllPermissions = new();
    bool IsLoading = true;
    bool ShowDialog = false;
    bool IsEdit = false;
    bool IsSaving = false;
    int EditRoleId = 0;
    string FormName = "";
    string FormDescription = "";
    List<int> SelectedPermissionIds = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        IsLoading = true;
        var rolesTask = Comm.GetAsync<List<RoleDto>>("api/role");
        var permsTask = Comm.GetAsync<List<PermissionDto>>("api/permission");
        await Task.WhenAll(rolesTask, permsTask);
        RoleList = rolesTask.Result ?? new();
        AllPermissions = permsTask.Result ?? new();
        IsLoading = false;
    }

    void OpenCreateDialog()
    {
        IsEdit = false;
        EditRoleId = 0;
        FormName = "";
        FormDescription = "";
        SelectedPermissionIds = new();
        ShowDialog = true;
    }

    async Task OpenEditDialog(RoleDto role)
    {
        IsEdit = true;
        EditRoleId = role.Id;
        FormName = role.Name;
        FormDescription = role.Description;

        var detail = await Comm.GetAsync<RoleDetailDto>($"api/role/{role.Id}");
        SelectedPermissionIds = detail?.PermissionIds ?? new();

        ShowDialog = true;
    }

    void CloseDialog() => ShowDialog = false;

    void TogglePermission(int permId)
    {
        if (SelectedPermissionIds.Contains(permId))
            SelectedPermissionIds.Remove(permId);
        else
            SelectedPermissionIds.Add(permId);
    }

    bool IsCategorySelected(string category)
    {
        var catPerms = AllPermissions.Where(p => p.Category == category).Select(p => p.Id);
        return catPerms.All(id => SelectedPermissionIds.Contains(id));
    }

    void ToggleCategory(string category)
    {
        var catPerms = AllPermissions.Where(p => p.Category == category).Select(p => p.Id).ToList();
        if (IsCategorySelected(category))
            SelectedPermissionIds.RemoveAll(id => catPerms.Contains(id));
        else
            SelectedPermissionIds.AddRange(catPerms.Except(SelectedPermissionIds));
    }

    async Task SaveRole()
    {
        if (string.IsNullOrWhiteSpace(FormName))
        {
            await JS.InvokeVoidAsync("alert", "نام نقش الزامی است");
            return;
        }

        IsSaving = true;
        try
        {
            var payload = new
            {
                Name = FormName,
                Description = FormDescription,
                PermissionIds = SelectedPermissionIds
            };

            if (IsEdit)
                await Comm.PutAsync<object>($"api/role/{EditRoleId}", payload);
            else
                await Comm.PostAsync<object>("api/role", payload);

            await LoadData();
            ShowDialog = false;
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"خطا: {ex.Message}");
        }
        finally
        {
            IsSaving = false;
        }
    }

    async Task DeleteRole(RoleDto role)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"آیا از حذف نقش «{role.Name}» مطمئن هستید؟");
        if (!confirmed) return;

        await Comm.DeleteAsync($"api/role/{role.Id}");
        await LoadData();
    }
}
