@page "/admin/messages"
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IModalService Modal
@inject IAlertService Alert
@inject IJSRuntime JS
@using Pdd.ir.Shared.Helpers

<PageTitle>@(T.CurrentLanguage == "fa" ? "پیام‌ها" : "Messages") | PDD</PageTitle>

<div class="page-enter">
    <PddTable TItem="ContactDto"
              Items="@Items"
              Title="@(T.CurrentLanguage == "fa" ? "پیام‌های دریافتی" : "Messages")"
              Subtitle="@(T.CurrentLanguage == "fa" ? "پیام‌های دریافتی از فرم تماس" : "Messages from contact form")"
              IsLoading="@IsLoading"
              PageSize="10"
              CanInsert="false"
              CanEdit="false"
              CanDelete="true"
              Columns="@_columns"
              OnDelete="Delete"
              DeleteMessageSelector="@(x => $"آیا از حذف پیام «{x.Name}» مطمئن هستید؟")" />
</div>

@code {
    List<ContactDto> Items = new();
    bool IsLoading = true;

    List<PddTableColumn<ContactDto>> _columns = new()
    {
        new() { Title = "نام", GetValue = x => x.Name },
        new() { Title = "ایمیل", GetValue = x => x.Email },
        new() { Title = "موضوع", GetValue = x => x.Subject },
        new() { Title = "تاریخ", Template = c => builder =>
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "style", "font-size:12px;");
            builder.AddContent(2, DateHelper.ToShamsiWithTime(DateHelper.ToUnix(c.CreatedAt)));
            builder.CloseElement();
        }},
        new() { Title = "وضعیت", Template = c => builder =>
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", $"badge {(c.IsRead ? "bg-secondary" : "bg-primary")}");
            builder.AddContent(2, c.IsRead ? "خوانده شده" : "جدید");
            builder.CloseElement();
        }}
    };

    protected override async Task OnInitializedAsync() => await Load();
    async Task Load() { IsLoading = true; Items = await Comm.GetAsync<List<ContactDto>>("api/contact") ?? new(); IsLoading = false; }
    async Task Delete(ContactDto x) { await Comm.DeleteAsync($"api/contact/{x.Id}"); await Alert.ShowSuccessAsync("موفق", "حذف شد"); await Load(); }

    public class ContactDto { public int Id { get; set; } public string Name { get; set; } = ""; public string Email { get; set; } = ""; public string Phone { get; set; } = ""; public string Subject { get; set; } = ""; public string Message { get; set; } = ""; public bool IsRead { get; set; } public DateTime CreatedAt { get; set; } }
}
