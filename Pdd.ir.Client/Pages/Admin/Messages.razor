@page "/admin/messages"
@implements IDisposable
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IAppStateService AppState
@inject IModalService Modal
@inject IAlertService Alert
@inject IJSRuntime JS
@using Pdd.ir.Shared.Helpers

<PageTitle>@T.Text("admin_messages") | PDD</PageTitle>

<div class="page-enter">
    <PddTable TItem="ContactDto"
              Items="@Items"
              Title="@T.Text("admin_messages")"
              Subtitle="@(T.CurrentLanguage == "fa" ? "پیام‌های دریافتی از فرم تماس" : "Messages from contact form")"
              IsLoading="@IsLoading"
              PageSize="10"
              CanInsert="false"
              CanEdit="false"
              CanDelete="true"
              Columns="@_columns"
              OnDelete="Delete"
              DeleteMessageSelector="@(x => T.Text("are_you_sure_delete"))" />
</div>

@code {
    List<ContactDto> Items = new();
    bool IsLoading = true;
    List<PddTableColumn<ContactDto>> _columns = new()
    {
        new() { Title = "نام", GetValue = x => x.Name },
        new() { Title = "ایمیل", GetValue = x => x.Email },
        new() { Title = "موضوع", GetValue = x => x.Subject },
        new() { Title = "تاریخ", Template = c => builder => { builder.OpenElement(0, "span"); builder.AddAttribute(1, "style", "font-size:12px;"); builder.AddContent(2, DateHelper.ToShamsiWithTime(DateHelper.ToUnix(c.CreatedAt))); builder.CloseElement(); }},
        new() { Title = "وضعیت", Template = c => builder => { builder.OpenElement(0, "span"); builder.AddAttribute(1, "class", $"badge {(c.IsRead ? "bg-secondary" : "bg-primary")}"); builder.AddContent(2, c.IsRead ? "خوانده شده" : "جدید"); builder.CloseElement(); }}
    };
    protected override async Task OnInitializedAsync() { AppState.OnStateChanged += Refresh; await Load(); }
    void Refresh() => InvokeAsync(StateHasChanged);
    async Task Load() { IsLoading = true; Items = await Comm.GetAsync<List<ContactDto>>("api/contact") ?? new(); IsLoading = false; }
    async Task Delete(ContactDto x) { await Comm.DeleteAsync($"api/contact/{x.Id}"); await Alert.ShowSuccessAsync(T.Text("success"), T.Text("deleted_successfully")); await Load(); }
    public void Dispose() { AppState.OnStateChanged -= Refresh; }
    public class ContactDto { public int Id { get; set; } public string Name { get; set; } = ""; public string Email { get; set; } = ""; public string Phone { get; set; } = ""; public string Subject { get; set; } = ""; public string Message { get; set; } = ""; public bool IsRead { get; set; } public DateTime CreatedAt { get; set; } }
}
