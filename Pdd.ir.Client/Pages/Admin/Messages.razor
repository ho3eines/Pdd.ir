@page "/admin/messages"
@inject HttpClient Http
@inject ITranslateService T
@inject IJSRuntime JS

<PageTitle>@T.Text("admin_messages") | PDD</PageTitle>

<div class="d-flex align-items-center justify-between mb-4" style="padding-top:24px;">
    <div>
        <h1 style="font-size:28px;font-weight:700;">@T.Text("admin_messages")</h1>
        <p class="text-muted" style="font-size:14px;">@(T.CurrentLanguage == "fa" ? "پیام‌های دریافتی از فرم تماس" : "Messages received from contact form")</p>
    </div>
</div>

<section class="section" style="padding-top:0;">
    <div class="container">
        <div class="card">
            @if (_messages == null)
            {
                @for (int i = 0; i < 3; i++)
                {
                    <div class="skeleton skeleton-row mb-2"></div>
                }
            }
            else if (!_messages.Any())
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-chat-dots" style="font-size:2rem;"></i>
                    <p class="mt-2">@T.Text("no_data")</p>
                </div>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table style="width:100%;border-collapse:collapse;">
                        <thead>
                            <tr style="border-bottom:1px solid var(--pdd-border);">
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">#</th>
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "نام" : "Name")</th>
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "ایمیل" : "Email")</th>
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "موضوع" : "Subject")</th>
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "تاریخ" : "Date")</th>
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "وضعیت" : "Status")</th>
                                <th style="padding:12px;text-align:left;font-size:13px;color:var(--pdd-text-muted);">@(T.CurrentLanguage == "fa" ? "عملیات" : "Actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var msg in _messages)
                            {
                                <tr style="border-bottom:1px solid var(--pdd-border);@(!msg.IsRead ? "background:var(--pdd-primary-glow);" : "")">
                                    <td style="padding:12px;font-size:14px;">@msg.Id</td>
                                    <td style="padding:12px;font-size:14px;">@msg.Name</td>
                                    <td style="padding:12px;font-size:14px;">@msg.Email</td>
                                    <td style="padding:12px;font-size:14px;">@msg.Subject</td>
                                    <td style="padding:12px;font-size:14px;">@msg.CreatedAt.ToString("yyyy/MM/dd")</td>
                                    <td style="padding:12px;">
                                        @if (msg.IsRead)
                                        {
                                            <span style="padding:4px 10px;background:rgba(156,163,175,0.15);color:var(--pdd-text-muted);border-radius:100px;font-size:12px;font-weight:600;">@(T.CurrentLanguage == "fa" ? "خوانده شده" : "Read")</span>
                                        }
                                        else
                                        {
                                            <span style="padding:4px 10px;background:var(--pdd-primary-glow);color:var(--pdd-primary);border-radius:100px;font-size:12px;font-weight:600;">@(T.CurrentLanguage == "fa" ? "جدید" : "New")</span>
                                        }
                                    </td>
                                    <td style="padding:12px;">
                                        <button class="btn btn-sm btn-glass me-1" @onclick="() => ViewMessage(msg)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button class="btn btn-sm btn-glass" style="color:#ef4444;" @onclick="() => DeleteAsync(msg)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>

@if (_selectedMessage != null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5);z-index:10000;">
        <div class="modal-dialog">
            <div class="modal-content" style="background:var(--pdd-bg-2);border:1px solid var(--pdd-border);border-radius:var(--pdd-radius-lg);">
                <div class="modal-header" style="border-bottom:1px solid var(--pdd-border);padding:16px 24px;">
                    <h5 class="modal-title" style="font-size:18px;font-weight:600;">@(T.CurrentLanguage == "fa" ? "پیام از" : "Message from") @_selectedMessage.Name</h5>
                    <button type="button" class="btn btn-sm btn-glass" @onclick="CloseMessage"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="modal-body" style="padding:24px;">
                    <div style="display:grid;gap:12px;">
                        <div><strong>@(T.CurrentLanguage == "fa" ? "ایمیل:" : "Email:")</strong> @_selectedMessage.Email</div>
                        <div><strong>@(T.CurrentLanguage == "fa" ? "تلفن:" : "Phone:")</strong> @(_selectedMessage.Phone ?? "-")</div>
                        <div><strong>@(T.CurrentLanguage == "fa" ? "موضوع:" : "Subject:")</strong> @(_selectedMessage.Subject ?? "-")</div>
                        <hr style="border-color:var(--pdd-border);" />
                        <p style="line-height:1.8;">@_selectedMessage.Message</p>
                    </div>
                </div>
                <div class="modal-footer" style="border-top:1px solid var(--pdd-border);padding:16px 24px;">
                    <button class="btn btn-glass" @onclick="CloseMessage">@(T.CurrentLanguage == "fa" ? "بستن" : "Close")</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ContactDto>? _messages;
    private ContactDto? _selectedMessage;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<ContactDto>>>("api/contact");
            _messages = response?.Data?.ToList();
        }
        catch { _messages = new List<ContactDto>(); }
    }

    private async Task ViewMessage(ContactDto msg)
    {
        _selectedMessage = msg;
        if (!msg.IsRead)
        {
            try
            {
                await Http.PutAsJsonAsync($"api/contact/{msg.Id}/read", new { });
                msg.IsRead = true;
            }
            catch { }
        }
    }

    private void CloseMessage() { _selectedMessage = null; }

    private async Task DeleteAsync(ContactDto msg)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"آیا از حذف پیام «{msg.Name}» مطمئن هستید؟");
        if (!confirmed) return;
        await Http.DeleteAsync($"api/contact/{msg.Id}");
        await LoadData();
    }

    public class ContactDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string? Phone { get; set; }
        public string Subject { get; set; } = "";
        public string Message { get; set; } = "";
        public bool IsRead { get; set; }
        public DateTime CreatedAt { get; set; }
    }

    public class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public T? Data { get; set; }
    }
}
