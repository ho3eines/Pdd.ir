@page "/admin/messages"
@implements IDisposable
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IModalService Modal
@inject IAlertService Alert
@inject IJSRuntime JS
@using Pdd.ir.Shared.Helpers

<PageTitle>@T.Text("admin_messages") | PDD</PageTitle>

<div class="page-enter">
    <PddTable TItem="ContactDto"
              Items="@Items"
              Title="@T.Text("admin_messages")"
              Subtitle="@T.Text("contact_messages_guide")"
              IsLoading="@IsLoading"
              PageSize="10"
              CanInsert="false"
              CanEdit="false"
              CanDelete="true"
              Columns="@GetColumns()"
              OnDelete="Delete"
              DeleteMessageSelector="@(x => T.Text("are_you_sure_delete"))" />
</div>

@code {
    List<ContactDto> Items = new();
    bool IsLoading = true;

    List<PddTableColumn<ContactDto>> GetColumns() => new()
    {
        new() { Title = T.Text("name"), GetValue = x => x.Name },
        new() { Title = T.Text("email_field"), GetValue = x => x.Email },
        new() { Title = T.Text("subject_field"), GetValue = x => x.Subject },
        new() { Title = T.Text("date"), Template = c => builder => { builder.OpenElement(0, "span"); builder.AddAttribute(1, "style", "font-size:12px;"); builder.AddContent(2, DateHelper.ToShamsiWithTime(DateHelper.ToUnix(c.CreatedAt))); builder.CloseElement(); }},
        new() { Title = T.Text("status"), Template = c => builder => { builder.OpenElement(0, "span"); builder.AddAttribute(1, "class", $"badge {(c.IsRead ? "bg-secondary" : "bg-primary")}"); builder.AddContent(2, c.IsRead ? T.Text("read") : T.Text("unread")); builder.CloseElement(); }}
    };

    protected override async Task OnInitializedAsync() { T.OnLanguageChanged += Refresh; await Load(); }
    void Refresh() => InvokeAsync(StateHasChanged);
    async Task Load() { IsLoading = true; Items = await Comm.GetAsync<List<ContactDto>>("api/contact") ?? new(); IsLoading = false; }
    async Task Delete(ContactDto x) { await Comm.DeleteAsync($"api/contact/{x.Id}"); await Alert.ShowSuccessAsync(T.Text("success"), T.Text("deleted_successfully")); await Load(); }
    public void Dispose() { T.OnLanguageChanged -= Refresh; }
    public class ContactDto { public int Id { get; set; } public string Name { get; set; } = ""; public string Email { get; set; } = ""; public string Phone { get; set; } = ""; public string Subject { get; set; } = ""; public string Message { get; set; } = ""; public bool IsRead { get; set; } public DateTime CreatedAt { get; set; } }
}
