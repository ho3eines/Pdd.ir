@page "/admin/settings"
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IJSRuntime JS
@inject IAlertService Alert

<PageTitle>@T.Text("settings") | PDD</PageTitle>

<div class="page-enter">
    <div class="mb-4" style="padding-top:24px;">
        <h1 style="font-size:28px;font-weight:700;">@(T.CurrentLanguage == "fa" ? "تنظیمات سایت" : "Site Settings")</h1>
        <p class="text-muted" style="font-size:14px;">@(T.CurrentLanguage == "fa" ? "مدیریت تنظیمات کلی سایت" : "Manage general site settings")</p>
    </div>

    @if (IsLoading)
    {
        <div class="skeleton skeleton-card" style="height:300px;"></div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-lg-6">
                <div class="glass-card fade-slide-in p-4">
                    <h5 style="font-size:14px;font-weight:700;margin-bottom:16px;">
                        <i class="bi bi-building me-2"></i>@(T.CurrentLanguage == "fa" ? "اطلاعات شرکت" : "Company Info")
                    </h5>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">@(T.CurrentLanguage == "fa" ? "نام شرکت" : "Company Name")</label>
                            <input type="text" class="form-control" @bind="CompanyName" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">@T.Text("phone")</label>
                            <input type="text" class="form-control" @bind="Phone" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">@T.Text("email")</label>
                            <input type="email" class="form-control" @bind="Email" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">@T.Text("address")</label>
                            <textarea class="form-control" rows="2" @bind="Address"></textarea>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="glass-card fade-slide-in p-4">
                    <h5 style="font-size:14px;font-weight:700;margin-bottom:16px;">
                        <i class="bi bi-share me-2"></i>@(T.CurrentLanguage == "fa" ? "شبکه‌های اجتماعی" : "Social Media")
                    </h5>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Instagram</label>
                            <input type="text" class="form-control" @bind="Instagram" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">LinkedIn</label>
                            <input type="text" class="form-control" @bind="LinkedIn" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Twitter</label>
                            <input type="text" class="form-control" @bind="Twitter" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Telegram</label>
                            <input type="text" class="form-control" @bind="Telegram" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <button class="btn btn-primary" @onclick="SaveSettings" disabled="@IsSaving">
                @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="bi bi-floppy me-1"></i>@T.Text("save")
            </button>
        </div>
    }
</div>

@code {
    string CompanyName = "Pdd.ir";
    string Phone = "021-12345678";
    string Email = "info@pdd.ir";
    string Address = "";
    string Instagram = "";
    string LinkedIn = "";
    string Twitter = "";
    string Telegram = "";
    bool IsLoading = true;
    bool IsSaving = false;

    protected override async Task OnInitializedAsync()
    {
        var data = await Comm.GetAsync<List<SettingItem>>("api/settings");
        if (data != null)
        {
            foreach (var item in data)
            {
                switch (item.Key)
                {
                    case "CompanyName": CompanyName = item.Value; break;
                    case "Phone": Phone = item.Value; break;
                    case "Email": Email = item.Value; break;
                    case "Address": Address = item.Value; break;
                    case "Instagram": Instagram = item.Value; break;
                    case "LinkedIn": LinkedIn = item.Value; break;
                    case "Twitter": Twitter = item.Value; break;
                    case "Telegram": Telegram = item.Value; break;
                }
            }
        }
        IsLoading = false;
    }

    async Task SaveSettings()
    {
        IsSaving = true;
        try
        {
            var items = new Dictionary<string, string>
            {
                ["CompanyName"] = CompanyName,
                ["Phone"] = Phone,
                ["Email"] = Email,
                ["Address"] = Address,
                ["Instagram"] = Instagram,
                ["LinkedIn"] = LinkedIn,
                ["Twitter"] = Twitter,
                ["Telegram"] = Telegram
            };
            foreach (var kv in items)
            {
                await Comm.PutAsync<object>($"api/settings/{kv.Key}", new { Value = kv.Value });
            }
            await Alert.ShowSuccessAsync(T.Text("success"), T.Text("saved_successfully"));
        }
        catch (Exception ex) { await Alert.ShowErrorAsync(T.Text("error"), ex.Message); }
        finally { IsSaving = false; }
    }

    public class SettingItem
    {
        public string Key { get; set; } = "";
        public string Value { get; set; } = "";
    }
}
