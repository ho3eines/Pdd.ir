@page "/blog"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>بلاگ | Pdd.ir</PageTitle>

<PageHeader Title="بلاگ" Subtitle="اخبار و مقالات تخصصی Pdd.ir" />

<section class="section">
    <div class="container">
        @if (_posts == null)
        {
            <div class="row g-4">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="skeleton skeleton-card" style="height:320px;"></div>
                    </div>
                }
            </div>
        }
        else if (!_posts.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-journal-x" style="font-size:3rem;color:var(--text-secondary);"></i>
                <p class="mt-3 text-secondary">هنوز مقاله‌ای منتشر نشده است</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var post in _posts)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <AnimatedSection AnimationType="fade-up">
                            <a href="/blog/@post.Slug" class="text-decoration-none">
                                <div class="blog-card">
                                    <div class="blog-card-image">
                                        <i class="bi bi-journal-richtext"></i>
                                    </div>
                                    <div class="blog-card-body">
                                        <div class="blog-card-meta">
                                            <span><i class="bi bi-person me-1"></i>@post.Author</span>
                                            <span><i class="bi bi-calendar me-1"></i>@post.CreatedAt.ToString("yyyy/MM/dd")</span>
                                            <span><i class="bi bi-eye me-1"></i>@post.ViewCount</span>
                                        </div>
                                        <h5 class="text-white mb-2">@post.Title</h5>
                                        <p class="text-secondary" style="font-size:0.9rem;">@post.Summary</p>
                                    </div>
                                </div>
                            </a>
                        </AnimatedSection>
                    </div>
                }
            </div>
        }
    </div>
</section>

@code {
    private List<BlogDto>? _posts;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<BlogDto>>>("api/blog");
            _posts = response?.Data?.ToList();
        }
        catch
        {
            _posts = new List<BlogDto>();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("initScrollAnimations"); } catch { }
        }
    }
}
