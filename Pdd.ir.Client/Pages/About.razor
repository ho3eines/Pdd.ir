@page "/about"
@inject IJSRuntime JS

<PageTitle>درباره ما | Pdd.ir</PageTitle>

<PageHeader Title="درباره ما" Subtitle="بیش از ۱۰ سال تجربه در توسعه نرم‌افزارهای سازمانی" />

<section class="section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-12 col-lg-6">
                <AnimatedSection AnimationType="slide-left">
                    <h2>شرکت Pdd.ir</h2>
                    <p class="mb-3">
                        ما یک تیم متخصص و با تجربه در زمینه توسعه نرم‌افزارهای سازمانی هستیم.
                        با بیش از ۱۰ سال فعالیت، راهکارهای نوینی برای بیمارستان‌ها، مراکز درمانی
                        و سازمان‌های مالی ارائه داده‌ایم.
                    </p>
                    <p>
                        هدف ما ارتقای سطح فناوری در سازمان‌های ایرانی و کمک به بهبود فرآیندهای
                        مدیریتی از طریق نرم‌افزارهای مدرن و کارآمد است.
                    </p>
                </AnimatedSection>
            </div>
            <div class="col-12 col-lg-6">
                <AnimatedSection AnimationType="slide-right">
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-number" data-count="10">۰</div>
                            <div class="stat-label">سال تجربه</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-number" data-count="50">۰</div>
                            <div class="stat-label">پروژه موفق</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-number" data-count="30">۰</div>
                            <div class="stat-label">مشتری راضی</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-number">۲۴/۷</div>
                            <div class="stat-label">پشتیبانی</div>
                        </div>
                    </div>
                </AnimatedSection>
            </div>
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <AnimatedSection AnimationType="fade-up">
            <h2 class="section-title">ارزش‌های ما</h2>
        </AnimatedSection>
        <div class="row g-4">
            <div class="col-12 col-md-4">
                <AnimatedSection AnimationType="scale-up">
                    <div class="value-card glow-hover">
                        <i class="bi bi-lightbulb"></i>
                        <h4>نوآوری</h4>
                        <p>همیشه در جستجوی راه‌حل‌های نوین هستیم</p>
                    </div>
                </AnimatedSection>
            </div>
            <div class="col-12 col-md-4">
                <AnimatedSection AnimationType="scale-up">
                    <div class="value-card glow-hover">
                        <i class="bi bi-people"></i>
                        <h4>کار تیمی</h4>
                        <p>موفقیت ما مدیون همکاری تیمی است</p>
                    </div>
                </AnimatedSection>
            </div>
            <div class="col-12 col-md-4">
                <AnimatedSection AnimationType="scale-up">
                    <div class="value-card glow-hover">
                        <i class="bi bi-award"></i>
                        <h4>کیفیت</h4>
                        <p>کیفیت در تمام مراحل توسعه اولویت ماست</p>
                    </div>
                </AnimatedSection>
            </div>
        </div>
    </div>
</section>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("initScrollAnimations"); await JS.InvokeVoidAsync("initCounters"); } catch { }
        }
    }
}
