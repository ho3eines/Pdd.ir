@page "/about"
@inject ITranslateService T
@inject IJSRuntime JS

<PageTitle>@T.Text("about") | PDD</PageTitle>

<PageHeader Title="@T.Text("about")" Subtitle="@(T.CurrentLanguage == "fa" ? "شرکت مهندسی طراح داده پیشرو" : "PDD Engineering Company")" />

<section class="section">
    <div class="container">
        <div class="contact-grid" style="text-align:center;">
            <div class="reveal" style="text-align:right;">
                <p style="line-height:2;color:var(--pdd-text-muted);font-size:15px;">
                    @(T.CurrentLanguage == "fa"
                        ? "طراح داده پیشرو به شماره ثبت ۲۵۶۳۷۴ با مسئولیت محدود در سال ۱۳۸۳ فعالیت خود را توسط یک جمع ۳ نفره بدون سرمایه اولیه به همراه ۲ کیس کامپیوتر که در آن زمان متعلق به شرکت نبود آغاز کرد."
                        : "PDD Engineering Company with registration number 256374 started its activity in 2004 with a 3-person team without initial capital.")
                </p>
                <p style="line-height:2;color:var(--pdd-text-muted);font-size:15px;">
                    @(T.CurrentLanguage == "fa"
                        ? "در همان سال اول، اولین نسل نرم‌افزارهای تحت ویندوز با تکنولوژی .NET را با عنوان طب پرداز در کشور به کاربران ارائه نمود."
                        : "In the first year, it introduced the first generation of Windows-based software with .NET technology to users in the country.")
                </p>
                <p style="line-height:2;color:var(--pdd-text-muted);font-size:15px;">
                    @(T.CurrentLanguage == "fa"
                        ? "این شرکت هم اکنون به عنوان یکی از بزرگترین طراح و تولید کنندگان سیستم‌های جامع اطلاعات مدیریت بیمارستانی در ایران مشغول به فعالیت بوده و نرم‌افزارهای آن توسط کارشناسان مراکز درمانی به عنوان یکی از مطمئن‌ترین و پیشرفته‌ترین محصولات به کار گرفته می‌شود."
                        : "This company is currently one of the largest designers and producers of comprehensive hospital management information systems in Iran.")
                </p>
            </div>
            <div class="reveal">
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-number" data-count="22">۰</div>
                        <div class="stat-label">@T.Text("years_experience")</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number" data-count="110">۰</div>
                        <div class="stat-label">@T.Text("medical_centers")</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number" data-count="27">۰</div>
                        <div class="stat-label">@T.Text("subsystems")</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">۶</div>
                        <div class="stat-label">@(T.CurrentLanguage == "fa" ? "نرم‌افزار" : "Software")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title reveal">@(T.CurrentLanguage == "fa" ? "مسیر رشد شرکت" : "Company Growth Path")</h2>
        </div>
        <div class="stats-grid reveal">
            <div class="stat-card">
                <div class="stat-number" data-count="10">۰</div>
                <div class="stat-label">@(T.CurrentLanguage == "fa" ? "سال ۱۳۸۵" : "Year 2006")</div>
            </div>
            <div class="stat-card">
                <div class="stat-number" data-count="40">۰</div>
                <div class="stat-label">@(T.CurrentLanguage == "fa" ? "سال ۱۳۸۹" : "Year 2010")</div>
            </div>
            <div class="stat-card">
                <div class="stat-number" data-count="70">۰</div>
                <div class="stat-label">@(T.CurrentLanguage == "fa" ? "سال ۱۳۹۳" : "Year 2014")</div>
            </div>
            <div class="stat-card">
                <div class="stat-number" data-count="90">۰</div>
                <div class="stat-label">@(T.CurrentLanguage == "fa" ? "سال ۱۳۹۴" : "Year 2015")</div>
            </div>
        </div>
    </div>
</section>

<CorporateFooter />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("initScrollAnimations"); await JS.InvokeVoidAsync("initCounters"); } catch { }
        }
    }
}
