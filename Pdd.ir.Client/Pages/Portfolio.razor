@page "/portfolio"
@inject ITranslateService T
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>@T.Text("portfolio") | PDD</PageTitle>

<PageHeader Title="@T.Text("portfolio")" Subtitle="@(T.CurrentLanguage == "fa" ? "پروژه‌های موفق" : "Successful projects")" />

<section class="section">
    <div class="container">
        @if (_items == null)
        {
            <div class="masonry-grid">
                @for (int i = 0; i < 6; i++)
                {
                    <div class="skeleton" style="height:@(150 + (i % 3) * 50)px;margin-bottom:20px;"></div>
                }
            </div>
        }
        else if (!_items.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-images" style="font-size:3rem;color:var(--pdd-text-muted);"></i>
                <p class="mt-3 text-muted">@(T.CurrentLanguage == "fa" ? "هنوز نمونه کاری ثبت نشده است" : "No portfolio items yet")</p>
            </div>
        }
        else
        {
            <div class="masonry-grid">
                @foreach (var item in _items)
                {
                    <AnimatedSection AnimationType="fade-up">
                        <div class="portfolio-card">
                            <div style="height:@(180 + (item.Id % 3) * 40)px;background:linear-gradient(135deg, @(item.Category == "HIS" ? "var(--pdd-primary)" : "var(--pdd-secondary)") 0%, #8b5cf6 100%);display:flex;align-items:center;justify-content:center;overflow:hidden;">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Title" class="portfolio-card-img" />
                                }
                                else
                                {
                                    <i class="bi @(item.Category == "HIS" ? "bi-hospital" : "bi-calculator")" style="font-size:3rem;color:rgba(255,255,255,0.3);"></i>
                                }
                            </div>
                            <div class="portfolio-card-overlay">
                                <div>
                                    <span style="display:inline-block;padding:4px 12px;background:var(--pdd-primary);border-radius:100px;font-size:11px;font-weight:600;color:#fff;margin-bottom:8px;">@item.Category</span>
                                    <h5 style="color:#fff;margin-bottom:4px;">@item.Title</h5>
                                    <p style="color:rgba(255,255,255,0.7);font-size:0.85rem;">@item.Description</p>
                                </div>
                            </div>
                        </div>
                    </AnimatedSection>
                }
            </div>
        }
    </div>
</section>

<CorporateFooter />

@code {
    private List<PortfolioDto>? _items;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<PortfolioDto>>>("api/portfolio");
            _items = response?.Data?.ToList();
        }
        catch
        {
            _items = new List<PortfolioDto>();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("initScrollAnimations"); } catch { }
        }
    }
}
