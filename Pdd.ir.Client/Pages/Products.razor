@page "/products"
@inject ICommunicationService Comm
@inject ITranslateService T
@inject IJSRuntime JS

<PageTitle>@(T.CurrentLanguage == "fa" ? "محصولات" : "Products") | PDD</PageTitle>

<PageHeader Title="@(T.CurrentLanguage == "fa" ? "محصولات" : "Products")" Subtitle="@(T.CurrentLanguage == "fa" ? "نرم‌افزارهای درمانی طراح داده پیشرو" : "PDD Medical Software")" />

<section class="section">
    <div class="container">
        @if (IsLoading)
        {
            <div class="row g-4">
                @for (int i = 0; i < 6; i++)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="skeleton skeleton-card" style="height:280px;"></div>
                    </div>
                }
            </div>
        }
        else if (!ProductList.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-box" style="font-size:3rem;color:var(--text-secondary);"></i>
                <p class="mt-3" style="color:var(--text-secondary);">@(T.CurrentLanguage == "fa" ? "هنوز محصولی ثبت نشده" : "No products yet")</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var p in ProductList)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <AnimatedSection AnimationType="fade-up">
                            <div class="glass-card hover-lift fade-slide-in p-4" style="height:100%;cursor:pointer;" @onclick="() => ShowDetail(p)">
                                <div style="width:56px;height:56px;border-radius:14px;background:rgba(13,110,253,0.1);display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
                                    <i class="bi bi-box-seam" style="font-size:24px;color:var(--pdd-primary);"></i>
                                </div>
                                <h5 style="font-size:16px;font-weight:700;margin-bottom:8px;">@p.Title</h5>
                                <p style="font-size:13px;color:var(--text-secondary);margin-bottom:12px;">@p.Subtitle</p>
                                <span class="badge bg-info" style="font-size:10px;">@p.Category</span>
                            </div>
                        </AnimatedSection>
                    </div>
                }
            </div>
        }
    </div>
</section>

@if (SelectedProduct != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.6);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content" style="background:var(--bg-secondary);border:1px solid var(--border-color);">
                <div class="modal-header" style="border-bottom:1px solid var(--border-color);">
                    <h5 class="modal-title" style="font-size:18px;font-weight:700;">@SelectedProduct.Title</h5>
                    <button type="button" class="btn-close" @onclick="CloseDetail"></button>
                </div>
                <div class="modal-body">
                    <p style="font-size:14px;color:var(--text-secondary);margin-bottom:16px;">@SelectedProduct.Subtitle</p>
                    @if (!string.IsNullOrEmpty(SelectedProduct.Description))
                    {
                        <div style="line-height:1.8;font-size:14px;color:var(--text-secondary);">@((MarkupString)SelectedProduct.Description)</div>
                    }
                    @if (!string.IsNullOrEmpty(SelectedProduct.Features))
                    {
                        <div class="mt-4">
                            <h6 style="font-size:13px;font-weight:700;margin-bottom:8px;">@(T.CurrentLanguage == "fa" ? "ویژگی‌ها" : "Features")</h6>
                            <div style="display:flex;flex-wrap:wrap;gap:8px;">
                                @foreach (var f in ParseFeatures(SelectedProduct.Features))
                                {
                                    <span style="padding:4px 12px;background:rgba(13,110,253,0.08);border:1px solid rgba(13,110,253,0.15);border-radius:100px;font-size:12px;">@f</span>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer" style="border-top:1px solid var(--border-color);">
                    <a href="/contact" class="btn btn-primary">
                        <i class="bi bi-headset me-1"></i>@(T.CurrentLanguage == "fa" ? "مشاوره رایگان" : "Free Consultation")
                    </a>
                </div>
            </div>
        </div>
    </div>
}

<CorporateFooter />

@code {
    List<ProductDto> ProductList = new();
    ProductDto? SelectedProduct;
    bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        ProductList = await Comm.GetAsync<List<ProductDto>>("api/product") ?? new();
        IsLoading = false;
    }

    void ShowDetail(ProductDto p) => SelectedProduct = p;
    void CloseDetail() => SelectedProduct = null;

    List<string> ParseFeatures(string json)
    {
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(json) ?? new();
        }
        catch { return new(); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) { try { await JS.InvokeVoidAsync("initScrollAnimations"); } catch { } }
    }

    public class ProductDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Subtitle { get; set; } = "";
        public string Description { get; set; } = "";
        public string Features { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string Category { get; set; } = "";
        public int SortOrder { get; set; }
        public bool IsActive { get; set; }
    }
}
