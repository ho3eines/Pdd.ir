@page "/products"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>محصولات | Pdd.ir</PageTitle>

<PageHeader Title="محصولات ما" Subtitle="نرم‌افزارهای مدرن و کارآمد برای سازمان شما" />

<section class="section">
    <div class="container">
        <div class="row g-4">
            @if (_products == null)
            {
                @for (int i = 0; i < 4; i++)
                {
                    <div class="col-12 col-md-6">
                        <div class="skeleton skeleton-card"></div>
                    </div>
                }
            }
            else
            {
                @foreach (var product in _products)
                {
                    <div class="col-12 col-md-6">
                        <AnimatedSection AnimationType="fade-up">
                            <div class="product-detail-card tilt-card">
                                <div class="product-header">
                                    <div class="product-icon-lg">
                                        <i class="bi @(product.Category == "HIS" ? "bi-hospital" : "bi-calculator")"></i>
                                    </div>
                                    <div>
                                        <h3>@product.Title</h3>
                                        <p class="text-muted">@product.Subtitle</p>
                                    </div>
                                </div>
                                <p>@product.Description</p>
                                @if (!string.IsNullOrEmpty(product.Features))
                                {
                                    <div class="features-list">
                                        @foreach (var feature in ParseFeatures(product.Features))
                                        {
                                            <div class="feature-item">
                                                <i class="bi bi-check-circle-fill text-success"></i>
                                                <span>@feature</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </AnimatedSection>
                    </div>
                }
            }
        </div>
    </div>
</section>

@code {
    private List<ProductDto>? _products;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<ProductDto>>>("api/product");
            _products = response?.Data;
        }
        catch
        {
            _products = new List<ProductDto>();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("initScrollAnimations"); await JS.InvokeVoidAsync("initTiltEffect"); } catch { }
        }
    }

    private List<string> ParseFeatures(string features)
    {
        try { return System.Text.Json.JsonSerializer.Deserialize<List<string>>(features) ?? new List<string>(); }
        catch { return features.Split('\n').Where(f => !string.IsNullOrWhiteSpace(f)).ToList(); }
    }
}
