@page "/products"
@inject ITranslateService T
@inject IJSRuntime JS

<PageTitle>@T.Text("products") | PDD</PageTitle>

<PageHeader Title="@T.Text("products")" Subtitle="@T.Text("hero_subtitle_3")" />

<section class="section">
    <div class="container">
        <div class="grid-3">
            <div class="card reveal">
                <div class="card-icon" style="background:rgba(13,110,253,0.15);color:var(--pdd-primary);">
                    <i class="bi bi-hospital"></i>
                </div>
                <h3>HIS</h3>
                <p>@T.Text("products_his") — @(T.CurrentLanguage == "fa" ? "از پذیرش تا ترخیص بیماران بستری" : "From admission to discharge of inpatients")</p>
            </div>
            <div class="card reveal">
                <div class="card-icon" style="background:rgba(248,28,229,0.15);color:var(--pdd-pink);">
                    <i class="bi bi-clipboard2-pulse"></i>
                </div>
                <h3>CIS</h3>
                <p>@T.Text("products_cis") — @(T.CurrentLanguage == "fa" ? "مدیریت تعرفه‌ها و ارسال نسخ بیمه‌ها" : "Tariff management and insurance prescription submission")</p>
            </div>
            <div class="card reveal">
                <div class="card-icon" style="background:rgba(121,40,202,0.15);color:var(--pdd-purple);">
                    <i class="bi bi-camera-reels"></i>
                </div>
                <h3>RIS</h3>
                <p>@T.Text("products_ris") — @(T.CurrentLanguage == "fa" ? "مدیریت MRI، سی‌تی اسکن و..." : "Management of MRI, CT Scan and...")</p>
            </div>
            <div class="card reveal">
                <div class="card-icon" style="background:rgba(80,227,194,0.15);color:var(--pdd-cyan);">
                    <i class="bi bi-lungs"></i>
                </div>
                <h3>LIS</h3>
                <p>@T.Text("products_lis") — @(T.CurrentLanguage == "fa" ? "سرعت بالا، زیبایی، امکانات متنوع" : "High speed, beauty, diverse features")</p>
            </div>
            <div class="card reveal">
                <div class="card-icon" style="background:rgba(13,110,253,0.15);color:var(--pdd-primary);">
                    <i class="bi bi-calculator"></i>
                </div>
                <h3>MIS</h3>
                <p>@T.Text("products_mis") — @(T.CurrentLanguage == "fa" ? "ارتباط میان نرم‌افزارهای درمانی و مالی" : "Connection between medical and financial software")</p>
            </div>
            <div class="card reveal">
                <div class="card-icon" style="background:rgba(248,28,229,0.15);color:var(--pdd-pink);">
                    <i class="bi bi-building"></i>
                </div>
                <h3>@T.Text("products_automation")</h3>
                <p>@(T.CurrentLanguage == "fa" ? "مدیریت گردش نامه‌ها و اطلاعات در سازمان" : "Management of organizational documents and information")</p>
            </div>
        </div>
    </div>
</section>

<CorporateFooter />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("initScrollAnimations"); } catch { }
        }
    }
}
