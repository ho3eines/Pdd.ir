@page "/"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Pdd.ir | شرکت نرم‌افزاری</PageTitle>

<!-- Hero Section -->
<section class="hero-section" style="position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 30% 20%, rgba(13,110,253,0.15) 0%, transparent 50%), radial-gradient(ellipse at 70% 80%, rgba(255,176,32,0.1) 0%, transparent 50%);pointer-events:none;"></div>
    <div class="hero-content position-relative" style="z-index:2;">
        <h1 class="hero-title">
            <span class="gradient-text-animated" style="font-size:3.5rem;">Pdd.ir</span>
        </h1>
        <p class="hero-subtitle">شرکت نرم‌افزاری پیشرو در توسعه راهکارهای سازمانی</p>
        <p class="hero-desc">
            ما با بیش از ۱۰ سال تجربه، نرم‌افزارهای مدرن و کارآمد برای بیمارستان‌ها و سازمان‌های مالی توسعه می‌دهیم.
        </p>
        <div class="hero-actions">
            <a href="/products" class="btn btn-primary btn-lg glow-hover">مشاهده محصولات</a>
            <a href="/contact" class="btn btn-outline-light btn-lg">تماس با ما</a>
        </div>
    </div>
    <div class="hero-visual position-relative" style="z-index:2;">
        <div class="floating-card card-1 parallax-card glass-card">
            <i class="bi bi-hospital"></i>
            <span>HIS</span>
        </div>
        <div class="floating-card card-2 parallax-card glass-card" style="animation-delay:0.5s;">
            <i class="bi bi-calculator"></i>
            <span>مالی</span>
        </div>
        <div class="floating-card card-3 parallax-card glass-card" style="animation-delay:1s;">
            <i class="bi bi-graph-up"></i>
            <span>گزارش</span>
        </div>
    </div>
</section>

<!-- Products Section -->
<section class="section" id="products">
    <div class="container">
        <AnimatedSection AnimationType="fade-up">
            <h2 class="section-title">محصولات ما</h2>
        </AnimatedSection>
        <div class="row g-4">
            @if (_products == null)
            {
                @for (int i = 0; i < 2; i++)
                {
                    <div class="col-12 col-md-6">
                        <div class="skeleton skeleton-card"></div>
                    </div>
                }
            }
            else
            {
                @foreach (var product in _products)
                {
                    <div class="col-12 col-md-6">
                        <AnimatedSection AnimationType="fade-up">
                            <div class="product-card tilt-card">
                                <div class="product-icon">
                                    <i class="bi @(product.Category == "HIS" ? "bi-hospital" : "bi-calculator")"></i>
                                </div>
                                <h3>@product.Title</h3>
                                <p class="text-muted">@product.Subtitle</p>
                                <a href="/products" class="btn btn-primary">مشاهده جزئیات</a>
                            </div>
                        </AnimatedSection>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="section section-alt">
    <div class="container">
        <AnimatedSection AnimationType="fade-up">
            <h2 class="section-title">چرا Pdd.ir؟</h2>
        </AnimatedSection>
        <div class="row g-4">
            <div class="col-12 col-sm-6 col-lg-3">
                <AnimatedSection AnimationType="scale-up">
                    <div class="feature-card glow-hover">
                        <div class="feature-icon"><i class="bi bi-shield-check"></i></div>
                        <h4>امنیت بالا</h4>
                        <p>رمزنگاری AES-256 و احراز هویت پیشرفته</p>
                    </div>
                </AnimatedSection>
            </div>
            <div class="col-12 col-sm-6 col-lg-3">
                <AnimatedSection AnimationType="scale-up">
                    <div class="feature-card glow-hover">
                        <div class="feature-icon"><i class="bi bi-speedometer2"></i></div>
                        <h4>سرعت بالا</h4>
                        <p>ارتباط WebSocket و عملکرد بهینه</p>
                    </div>
                </AnimatedSection>
            </div>
            <div class="col-12 col-sm-6 col-lg-3">
                <AnimatedSection AnimationType="scale-up">
                    <div class="feature-card glow-hover">
                        <div class="feature-icon"><i class="bi bi-phone"></i></div>
                        <h4>واکنش‌گرا</h4>
                        <p>طراحی مناسب برای تمام دستگاه‌ها</p>
                    </div>
                </AnimatedSection>
            </div>
            <div class="col-12 col-sm-6 col-lg-3">
                <AnimatedSection AnimationType="scale-up">
                    <div class="feature-card glow-hover">
                        <div class="feature-icon"><i class="bi bi-headset"></i></div>
                        <h4>پشتیبانی ۲۴/۷</h4>
                        <p>تیم پشتیبانی آماده خدمت‌رسانی</p>
                    </div>
                </AnimatedSection>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="section">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3">
                <AnimatedSection AnimationType="fade-up">
                    <div class="stat-card">
                        <i class="bi bi-calendar-check"></i>
                        <div class="stat-number" data-count="10">۰</div>
                        <div class="stat-label">سال تجربه</div>
                    </div>
                </AnimatedSection>
            </div>
            <div class="col-6 col-md-3">
                <AnimatedSection AnimationType="fade-up">
                    <div class="stat-card">
                        <i class="bi bi-check-circle"></i>
                        <div class="stat-number" data-count="50">۰</div>
                        <div class="stat-label">پروژه موفق</div>
                    </div>
                </AnimatedSection>
            </div>
            <div class="col-6 col-md-3">
                <AnimatedSection AnimationType="fade-up">
                    <div class="stat-card">
                        <i class="bi bi-people"></i>
                        <div class="stat-number" data-count="30">۰</div>
                        <div class="stat-label">مشتری راضی</div>
                    </div>
                </AnimatedSection>
            </div>
            <div class="col-6 col-md-3">
                <AnimatedSection AnimationType="fade-up">
                    <div class="stat-card">
                        <i class="bi bi-headset"></i>
                        <div class="stat-number">۲۴/۷</div>
                        <div class="stat-label">پشتیبانی</div>
                    </div>
                </AnimatedSection>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
    <div class="container text-center">
        <AnimatedSection AnimationType="fade-up">
            <h2>آماده شروع هستید؟</h2>
            <p class="mb-4">با ما تماس بگیرید و مشاوره رایگان دریافت کنید</p>
            <a href="/contact" class="btn btn-light btn-lg glow-hover">تماس با ما</a>
        </AnimatedSection>
    </div>
</section>

<!-- Footer -->
<footer class="footer">
    <div class="container">
        <div class="row g-4">
            <div class="col-12 col-md-4">
                <div class="footer-brand gradient-text">Pdd.ir</div>
                <p class="text-secondary">شرکت نرم‌افزاری پیشرو در توسعه راهکارهای سازمانی</p>
            </div>
            <div class="col-6 col-md-2">
                <h6 class="text-white mb-3">لینک‌ها</h6>
                <ul class="footer-links">
                    <li><a href="/">خانه</a></li>
                    <li><a href="/products">محصولات</a></li>
                    <li><a href="/blog">بلاگ</a></li>
                    <li><a href="/portfolio">نمونه کارها</a></li>
                </ul>
            </div>
            <div class="col-6 col-md-3">
                <h6 class="text-white mb-3">تماس با ما</h6>
                <ul class="footer-links">
                    <li><i class="bi bi-telephone me-2"></i>۰۲۱-۱۲۳۴۵۶۷۸</li>
                    <li><i class="bi bi-envelope me-2"></i>info@pdd.ir</li>
                    <li><i class="bi bi-geo-alt me-2"></i>تهران، خیابان ولیعصر</li>
                </ul>
            </div>
            <div class="col-12 col-md-3">
                <h6 class="text-white mb-3">شبکه‌های اجتماعی</h6>
                <div class="d-flex gap-3">
                    <a href="#" class="text-secondary fs-5"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="text-secondary fs-5"><i class="bi bi-linkedin"></i></a>
                    <a href="#" class="text-secondary fs-5"><i class="bi bi-telegram"></i></a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            © ۲۰۲۶ Pdd.ir — تمامی حقوق محفوظ است
        </div>
    </div>
</footer>

@code {
    private List<ProductDto>? _products;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<ProductDto>>>("api/product");
            _products = response?.Data;
        }
        catch
        {
            _products = new List<ProductDto>();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("initHeroAnimation");
                await JS.InvokeVoidAsync("initMouseParallax");
                await JS.InvokeVoidAsync("initTiltEffect");
                await Task.Delay(500);
                await JS.InvokeVoidAsync("initScrollAnimations");
                await JS.InvokeVoidAsync("initCounters");
            }
            catch { }
        }
    }
}
