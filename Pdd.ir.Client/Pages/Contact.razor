@page "/contact"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>تماس با ما | PDD</PageTitle>

<section class="section" style="padding-top:120px;">
    <div class="content">
        <h2 class="section-title reveal">تماس با ما</h2>
        <div class="contact-grid">
            <div class="contact-info reveal">
                <div class="info-item">
                    <i class="bi bi-geo-alt"></i>
                    <div>
                        <strong>آدرس</strong>
                        <p>تهران - شهرک غرب - بلوار دریا - پلاک ۲۴۰ - واحد ۱</p>
                    </div>
                </div>
                <div class="info-item">
                    <i class="bi bi-telephone"></i>
                    <div>
                        <strong>تلفن</strong>
                        <p dir="ltr">021-88368070</p>
                    </div>
                </div>
                <div class="info-item">
                    <i class="bi bi-fax"></i>
                    <div>
                        <strong>فکس</strong>
                        <p dir="ltr">021-88360807</p>
                    </div>
                </div>
                <div class="info-item">
                    <i class="bi bi-envelope"></i>
                    <div>
                        <strong>ایمیل</strong>
                        <p dir="ltr">pdd_tdp@yahoo.com</p>
                    </div>
                </div>
                <div class="info-item">
                    <i class="bi bi-clock"></i>
                    <div>
                        <strong>ساعات کار</strong>
                        <p>شنبه تا چهارشنبه: ۰۸:۰۰ - ۱۶:۰۰</p>
                        <p>پنج‌شنبه: ۰۸:۰۰ - ۱۲:۰۰</p>
                        <p>جمعه: تعطیل</p>
                    </div>
                </div>
            </div>
            <div class="contact-form reveal">
                <form onsubmit="event.preventDefault();">
                    <input type="text" placeholder="نام شما" class="form-input" />
                    <input type="email" placeholder="ایمیل" class="form-input" />
                    <input type="text" placeholder="موضوع" class="form-input" />
                    <textarea placeholder="پیام شما" rows="5" class="form-input"></textarea>
                    <button type="submit" class="btn-glow">ارسال پیام</button>
                </form>
            </div>
        </div>
    </div>
</section>

<CorporateFooter />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("initScrollAnimations"); } catch { }
        }
    }
}
