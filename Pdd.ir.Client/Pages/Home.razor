@page "/"
@inject IJSRuntime JS
@inject ITranslateService T
@inject ICommunicationService Comm
@implements IAsyncDisposable

<div class="home-fullscreen" id="homeScreen">

    <div class="mouse-glow" id="mouseGlow"></div>
    <canvas class="home-particles" id="homeParticles"></canvas>

    <!-- Background Images Layer -->
    <div class="home-bg-layer">
        @for (int i = 0; i < _slides.Count; i++)
        {
            <div class="home-bg-img @(_currentSlide == i ? "active" : "")" style="background-image:url('@_slides[i].ImageUrl')"></div>
        }
        <div class="home-bg-overlay"></div>
        <div class="home-bg-grain"></div>
    </div>

    <!-- Top bar: Logo + Lang -->
    <div class="home-topbar">
        <a href="/" class="home-logo">
            <span class="home-logo-text">PDD</span>
            <span class="home-logo-sub">@(T.CurrentLanguage == "fa" ? "طراح داده پیشرو" : "PDD Engineering")</span>
        </a>
        <div class="home-topbar-actions">
            <button class="lang-pill" @onclick="ToggleLang" aria-label="Switch language">
                <span class="lang-pill-icon"><i class="bi bi-translate"></i></span>
                <span class="lang-pill-text" key="@T.CurrentLanguage">@(T.CurrentLanguage == "fa" ? "EN" : "FA")</span>
            </button>
            <button class="theme-pill" @onclick="ToggleTheme" aria-label="Toggle theme">
                <span class="theme-pill-icon"><i class="bi @(_isDark ? "bi-sun" : "bi-moon")"></i></span>
            </button>
            <button class="login-pill" aria-label="Login" @onclick="GoToLogin">
                <i class="bi bi-box-arrow-in-right"></i>
            </button>
        </div>
    </div>

    <!-- Main Content: Products + Center -->
    <div class="home-main">

        <!-- Left: Products -->
        <div class="home-products-panel">
            <div class="products-header">
                <span class="products-label">@(T.CurrentLanguage == "fa" ? "محصولات ما" : "Our Products")</span>
                <div class="products-divider"></div>
            </div>
            <div class="products-list" id="productsList">
                @for (int i = 0; i < _products.Count; i++)
                {
                    var p = _products[i];
                    var idx = i;
                    <div class="product-row" style="--i:@(idx)">
                        <div class="product-info">
                            <div class="product-icon" style="background:@(p.IconBg);color:@(p.IconColor)">
                                <i class="bi @p.Icon"></i>
                            </div>
                            <div class="product-text">
                                <span class="product-name">@(T.CurrentLanguage == "fa" ? p.NameFa : p.NameEn)</span>
                                <span class="product-sub">@(T.CurrentLanguage == "fa" ? p.SubFa : p.SubEn)</span>
                            </div>
                        </div>
                        <button class="product-btn" @onclick="() => NavigateToProduct(p.Route)">
                            <i class="bi bi-arrow-left-short"></i>
                        </button>
                    </div>
                }
            </div>

            <div class="products-footer">
                <a href="/contact" class="btn-glow-sm">
                    <i class="bi bi-headset"></i>
                    @(T.CurrentLanguage == "fa" ? "مشاوره رایگان" : "Free Consultation")
                </a>
            </div>
        </div>

        <!-- Right: Text Slider -->
        <div class="home-center">
            <div class="text-slider" id="textSlider">
                @for (int i = 0; i < _slides.Count; i++)
                {
                    var slide = _slides[i];
                    <div class="text-slide @(_currentSlide == i ? "active" : "") @(_prevSlide == i ? "leaving" : "")">
                        <div class="slide-badge">
                            <span class="badge-dot"></span>
                            @(T.CurrentLanguage == "fa" ? slide.BadgeFa : slide.BadgeEn)
                        </div>
                        <h1 class="slide-title">
                            <span class="gradient-text">@(T.CurrentLanguage == "fa" ? slide.TitleFa : slide.TitleEn)</span>
                        </h1>
                        <p class="slide-desc">@(T.CurrentLanguage == "fa" ? slide.DescFa : slide.DescEn)</p>
                    </div>
                }
            </div>

            <div class="slider-controls">
                <button class="slider-arrow" @onclick="PrevSlide" aria-label="Prev"><i class="bi bi-chevron-left"></i></button>
                <div class="slider-dots">
                    @for (int i = 0; i < _slides.Count; i++)
                    {
                        var idx = i;
                        <button class="slider-dot @(_currentSlide == idx ? "active" : "")" @onclick="() => GoToSlide(idx)"></button>
                    }
                </div>
                <button class="slider-arrow" @onclick="NextSlide" aria-label="Next"><i class="bi bi-chevron-right"></i></button>
            </div>

            <div class="slider-progress">
                <div class="slider-progress-bar" style="width:@(_progress)%"></div>
            </div>
        </div>
    </div>

    <!-- Bottom: Clients -->
    <CustomerShowcase Customers="_clients" />
</div>

@code {
    private int _currentSlide = 0;
    private int _prevSlide = -1;
    private double _progress = 0;
    private Timer? _slideTimer;
    private Timer? _progressTimer;
    private bool _isDark = true;

    private List<SlideItem> _slides => new()
    {
        new SlideItem
        {
            BadgeFa = "راهکار هوشمند", BadgeEn = "Smart Solution",
            TitleFa = "نرم‌افزار جامع مدیریت درمانی", TitleEn = "Comprehensive Healthcare Software",
            DescFa = "طراحی سیستم‌های مدرن برای بیمارستان‌ها و مراکز درمانی با بیش از ۲۲ سال تجربه",
            DescEn = "Modern systems for hospitals and medical centers with over 22 years of experience",
            ImageUrl = "https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=1920&q=80"
        },
        new SlideItem
        {
            BadgeFa = "پوشش جامع", BadgeEn = "Full Coverage",
            TitleFa = "۲۷ زیرسیستم یکپارچه", TitleEn = "27 Integrated Subsystems",
            DescFa = "از پذیرش بیمار تا ترخیص، از آزمایشگاه تا خزانه‌داری — همه در یک پلتفرم",
            DescEn = "From patient admission to discharge, lab to treasury — all in one platform",
            ImageUrl = "https://images.unsplash.com/photo-1551190822-a9ce113ac100?w=1920&q=80"
        },
        new SlideItem
        {
            BadgeFa = "پشتیبانی", BadgeEn = "Support",
            TitleFa = "پشتیبانی ۲۴ ساعته", TitleEn = "24/7 Support",
            DescFa = "بیش از ۱۱۰ مرکز درمانی در سراسر کشور به ما اعتماد کرده‌اند",
            DescEn = "Over 110 medical centers across the country trust us",
            ImageUrl = "https://images.unsplash.com/photo-1579684385127-1ef15d508118?w=1920&q=80"
        }
    };

    private List<ProductItem> _products => new()
    {
        new ProductItem { Icon = "bi-hospital", IconBg = "rgba(13,110,253,0.15)", IconColor = "#0D6EFD", NameFa = "HIS — بیمارستانی", NameEn = "HIS — Hospital", SubFa = "مدیریت جامع بیمارستان", SubEn = "Hospital Management", Route = "/products" },
        new ProductItem { Icon = "bi-clipboard2-pulse", IconBg = "rgba(248,28,229,0.15)", IconColor = "#f81ce5", NameFa = "CIS — درمانگاهی", NameEn = "CIS — Clinic", SubFa = "مدیریت کلینیک", SubEn = "Clinic Management", Route = "/products" },
        new ProductItem { Icon = "bi-camera-reels", IconBg = "rgba(121,40,202,0.15)", IconColor = "#7928ca", NameFa = "RIS — تصویربرداری", NameEn = "RIS — Imaging", SubFa = "مراکز MRI و CT", SubEn = "MRI & CT Centers", Route = "/products" },
        new ProductItem { Icon = "bi-lungs", IconBg = "rgba(80,227,194,0.15)", IconColor = "#50e3c2", NameFa = "LIS — آزمایشگاه", NameEn = "LIS — Laboratory", SubFa = "مدیریت آزمایشگاه", SubEn = "Lab Management", Route = "/products" },
        new ProductItem { Icon = "bi-calculator", IconBg = "rgba(13,110,253,0.15)", IconColor = "#0D6EFD", NameFa = "MIS — مالی اداری", NameEn = "MIS — Financial", SubFa = "حسابداری و خزانه", SubEn = "Accounting & Treasury", Route = "/products" },
        new ProductItem { Icon = "bi-building", IconBg = "rgba(248,28,229,0.15)", IconColor = "#f81ce5", NameFa = "اتوماسیون اداری", NameEn = "Office Automation", SubFa = "گردش نامه و بایگانی", SubEn = "Document & Filing", Route = "/products" }
    };

    private List<Customer> _clients = new();

    protected override async Task OnInitializedAsync()
    {
        // Load clients from database
        try
        {
            var clientsDto = await Comm.GetAsync<List<ClientDto>>("api/client") ?? new();
            _clients = clientsDto.Select(c => new Customer
            {
                Abbr = c.NameEn.Length >= 2 ? c.NameEn.Substring(0, 2) : c.NameEn,
                NameFa = c.Name,
                NameEn = c.NameEn,
                ImageUrl = c.ImageUrl
            }).ToList();
        }
        catch
        {
            _clients = new();
        }

        _slideTimer = new Timer(_ =>
        {
            InvokeAsync(() => { NextSlide(); StateHasChanged(); });
        }, null, 6000, 6000);

        _progressTimer = new Timer(_ =>
        {
            InvokeAsync(() =>
            {
                _progress += 1.67;
                if (_progress >= 100) _progress = 0;
                StateHasChanged();
            });
        }, null, 100, 100);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var savedTheme = await JS.InvokeAsync<string>("getTheme");
                _isDark = savedTheme != "light";
                await JS.InvokeVoidAsync("setTheme", _isDark ? "dark" : "light");
                StateHasChanged();

                var lang = T.CurrentLanguage;
                if (string.IsNullOrEmpty(lang)) lang = "fa";
                await JS.InvokeVoidAsync("setDocDirection", lang);
                await JS.InvokeVoidAsync("initHomeMouseGlow");
                await JS.InvokeVoidAsync("initHomeParticles");
                await JS.InvokeVoidAsync("initHomeProductReveal");
            }
            catch { }
        }
    }

    private void NextSlide()
    {
        _prevSlide = _currentSlide;
        _currentSlide = (_currentSlide + 1) % _slides.Count;
        _progress = 0;
    }

    private void PrevSlide()
    {
        _prevSlide = _currentSlide;
        _currentSlide = (_currentSlide - 1 + _slides.Count) % _slides.Count;
        _progress = 0;
    }

    private void GoToSlide(int index)
    {
        _prevSlide = _currentSlide;
        _currentSlide = index;
        _progress = 0;
    }

    private void NavigateToProduct(string route) => Navigation.NavigateTo(route);

    private void GoToLogin() => Navigation.NavigateTo("/login");

    private async Task ToggleLang()
    {
        var lang = T.CurrentLanguage == "fa" ? "en" : "fa";
        await T.LoadLanguageAsync(lang);
        await JS.InvokeVoidAsync("localStorage.setItem", "app_lang", lang);
        await JS.InvokeVoidAsync("setDocDirection", lang);
        StateHasChanged();
    }

    private async Task ToggleTheme()
    {
        var result = await JS.InvokeAsync<string>("toggleTheme");
        _isDark = result == "dark";
        StateHasChanged();
    }

    [Inject] private NavigationManager Navigation { get; set; } = default!;

    public async ValueTask DisposeAsync()
    {
        if (_slideTimer != null) await _slideTimer.DisposeAsync();
        if (_progressTimer != null) await _progressTimer.DisposeAsync();
        try { await JS.InvokeVoidAsync("disposeHomeMouseGlow"); } catch { }
        try { await JS.InvokeVoidAsync("disposeHomeParticles"); } catch { }
    }

    private class SlideItem
    {
        public string BadgeFa { get; set; } = "";
        public string BadgeEn { get; set; } = "";
        public string TitleFa { get; set; } = "";
        public string TitleEn { get; set; } = "";
        public string DescFa { get; set; } = "";
        public string DescEn { get; set; } = "";
        public string ImageUrl { get; set; } = "";
    }
    private class ProductItem
    {
        public string Icon { get; set; } = "";
        public string IconBg { get; set; } = "";
        public string IconColor { get; set; } = "";
        public string NameFa { get; set; } = "";
        public string NameEn { get; set; } = "";
        public string SubFa { get; set; } = "";
        public string SubEn { get; set; } = "";
        public string Route { get; set; } = "";
    }
}
