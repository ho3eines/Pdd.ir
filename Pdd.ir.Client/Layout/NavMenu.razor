@inject AuthService Auth
@inject ITranslateService T
@inject IAppStateService AppState
@implements IDisposable

<button class="admin-hamburger" id="adminHamburger" @onclick="ToggleSidebar" aria-label="Toggle menu">
    <i class="bi bi-list"></i>
</button>

<div class="admin-sidebar-overlay" id="sidebarOverlay" @onclick="ToggleSidebar"></div>

<div class="admin-sidebar" id="adminSidebar">
    <div class="admin-sidebar-header">
        <a href="/" class="admin-sidebar-logo">
            <span class="admin-sidebar-logo-text">PDD</span>
            <span class="admin-sidebar-logo-sub">@T.Text("admin_panel")</span>
        </a>
        <button class="admin-sidebar-close" @onclick="ToggleSidebar">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <nav class="admin-sidebar-nav">
        <div class="admin-nav-item">
            <NavLink class="admin-nav-link" href="admin" Match="NavLinkMatch.All">
                <span class="admin-nav-icon"><i class="bi bi-speedometer2"></i></span>
                <span class="admin-nav-text">@T.Text("dashboard")</span>
            </NavLink>
        </div>
        <div class="admin-nav-item">
            <NavLink class="admin-nav-link" href="admin/products">
                <span class="admin-nav-icon"><i class="bi bi-box-seam"></i></span>
                <span class="admin-nav-text">@T.Text("admin_products")</span>
            </NavLink>
        </div>
        <div class="admin-nav-item">
            <NavLink class="admin-nav-link" href="admin/blog">
                <span class="admin-nav-icon"><i class="bi bi-journal-richtext"></i></span>
                <span class="admin-nav-text">@T.Text("admin_blog")</span>
            </NavLink>
        </div>
        <div class="admin-nav-item">
            <NavLink class="admin-nav-link" href="admin/portfolio">
                <span class="admin-nav-icon"><i class="bi bi-images"></i></span>
                <span class="admin-nav-text">@T.Text("admin_portfolio")</span>
            </NavLink>
        </div>
        <div class="admin-nav-item">
            <NavLink class="admin-nav-link" href="admin/messages">
                <span class="admin-nav-icon"><i class="bi bi-chat-dots"></i></span>
                <span class="admin-nav-text">@T.Text("admin_messages")</span>
            </NavLink>
        </div>

        <div class="admin-nav-divider"></div>

        <div class="admin-nav-item">
            <NavLink class="admin-nav-link" href="admin/users">
                <span class="admin-nav-icon"><i class="bi bi-people"></i></span>
                <span class="admin-nav-text">@T.Text("admin_users")</span>
            </NavLink>
        </div>
        <div class="admin-nav-item">
            <NavLink class="admin-nav-link" href="admin/settings">
                <span class="admin-nav-icon"><i class="bi bi-gear"></i></span>
                <span class="admin-nav-text">@T.Text("admin_settings")</span>
            </NavLink>
        </div>
    </nav>

    <div class="admin-sidebar-footer">
        <a href="/" class="admin-sidebar-back">
            <i class="bi bi-arrow-right"></i>
            <span>@T.Text("back_to_site")</span>
        </a>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnToggleSidebar { get; set; }

    protected override void OnInitialized()
    {
        AppState.OnStateChanged += OnStateChanged;
        T.OnLanguageChanged += OnLanguageChanged;
    }

    void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task ToggleSidebar()
    {
        await OnToggleSidebar.InvokeAsync();
    }

    public void Dispose()
    {
        AppState.OnStateChanged -= OnStateChanged;
        T.OnLanguageChanged -= OnLanguageChanged;
    }
}
