@inject AuthService Auth

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <span class="gradient-text" style="font-weight:800;">Pdd.ir</span>
        </a>
    </div>
</div>

<nav class="flex-column">
    <div class="nav-item px-3">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            <span class="bi bi-house-door-fill" aria-hidden="true"></span> خانه
        </NavLink>
    </div>
    <div class="nav-item px-3">
        <NavLink class="nav-link" href="products">
            <span class="bi bi-box-seam" aria-hidden="true"></span> محصولات
        </NavLink>
    </div>
    <div class="nav-item px-3">
        <NavLink class="nav-link" href="blog">
            <span class="bi bi-journal-richtext" aria-hidden="true"></span> بلاگ
        </NavLink>
    </div>
    <div class="nav-item px-3">
        <NavLink class="nav-link" href="portfolio">
            <span class="bi bi-images" aria-hidden="true"></span> نمونه کارها
        </NavLink>
    </div>
    <div class="nav-item px-3">
        <NavLink class="nav-link" href="about">
            <span class="bi bi-info-circle" aria-hidden="true"></span> درباره ما
        </NavLink>
    </div>
    <div class="nav-item px-3">
        <NavLink class="nav-link" href="contact">
            <span class="bi bi-envelope" aria-hidden="true"></span> تماس با ما
        </NavLink>
    </div>

    @if (Auth.IsAuthenticated && Auth.HasAnyRole("Admin"))
    {
        <hr class="text-secondary mx-3 my-2" style="opacity:0.3;" />
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin">
                <span class="bi bi-speedometer2" aria-hidden="true"></span> داشبورد
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin/products">
                <span class="bi bi-box" aria-hidden="true"></span> مدیریت محصولات
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin/blog">
                <span class="bi bi-pencil-square" aria-hidden="true"></span> مدیریت بلاگ
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin/portfolio">
                <span class="bi bi-collection" aria-hidden="true"></span> مدیریت نمونه کارها
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin/messages">
                <span class="bi bi-chat-dots" aria-hidden="true"></span> پیام‌ها
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin/users">
                <span class="bi bi-people" aria-hidden="true"></span> کاربران
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin/settings">
                <span class="bi bi-gear" aria-hidden="true"></span> تنظیمات
            </NavLink>
        </div>
    }
</nav>

@code {
    [Parameter] public EventCallback OnToggleSidebar { get; set; }
}
