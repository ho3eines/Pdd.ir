@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject AuthService Auth
@inject NavigationManager Navigation
@implements IDisposable

@if (_isLandingPage)
{
    @Body
    <button class="global-theme-toggle" @onclick="ToggleTheme" title="@T.Text("toggle_theme")">
        <i class="bi @(_isDark ? "bi-sun" : "bi-moon")"></i>
    </button>
}
else
{
    <div class="admin-layout">
        <NavMenu OnToggleSidebar="ToggleSidebar" />

        <div class="admin-main">
            <div class="admin-topbar">
                <div class="admin-topbar-right">
                    <a href="/" class="admin-topbar-logo">
                        <span class="admin-topbar-logo-text">PDD</span>
                        <span class="admin-topbar-logo-sub">@T.Text("pdd_engineering")</span>
                    </a>
                </div>
                <div class="admin-topbar-left">
                    <div class="admin-topbar-actions">
                        <div class="connection-status">
                            <span class="connection-dot connected"></span>
                            <span>WS</span>
                        </div>
                        <button class="admin-topbar-pill" @onclick="ToggleTheme" title="@T.Text("toggle_theme")">
                            <i class="bi @(_isDark ? "bi-sun" : "bi-moon")"></i>
                        </button>
                        <button class="admin-topbar-pill lang-pill-mini" @onclick="ToggleLang">
                            <i class="bi bi-translate"></i>
                            <span>@(T.CurrentLanguage == "fa" ? "EN" : "FA")</span>
                        </button>
                        @if (Auth.IsAuthenticated)
                        {
                            <div class="admin-topbar-user">
                                <span class="admin-topbar-user-name">@Auth.FullName</span>
                                <button class="admin-topbar-pill" @onclick="Logout" title="@T.Text("logout")">
                                    <i class="bi bi-box-arrow-right"></i>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <article class="admin-content">
                @Body
            </article>
        </div>
    </div>
}

@code {
    private bool _isDark = true;
    private bool _isLandingPage;
    private bool _sidebarOpen;
    private bool _initialized;

    [Inject] private ITranslateService T { get; set; } = default!;
    [Inject] private IAppStateService AppState { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        Auth.OnAuthStateChanged += OnAuthChanged;
        AppState.OnStateChanged += OnAppStateChanged;
        T.OnLanguageChanged += OnLanguageChanged;
        Navigation.LocationChanged += OnLocationChanged;

        _isLandingPage = IsLandingPage(Navigation.Uri);

        // Load saved language from localStorage
        await T.InitializeAsync();

        try
        {
            var theme = await JS.InvokeAsync<string>("getTheme");
            _isDark = theme != "light";
        }
        catch { }

        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_initialized) return;

        var wasLanding = _isLandingPage;
        _isLandingPage = IsLandingPage(Navigation.Uri);

        if (wasLanding != _isLandingPage)
        {
            if (!_isLandingPage)
            {
                await Auth.LoadFromStorageAsync();
                if (!Auth.IsAuthenticated)
                {
                    Navigation.NavigateTo("/login");
                    return;
                }
            }
            StateHasChanged();
        }
    }

    private bool IsLandingPage(string uri)
    {
        var path = new Uri(uri).AbsolutePath.ToLower();
        var landingPaths = new[] { "/", "/products", "/blog", "/portfolio", "/about", "/contact", "/login" };
        return landingPaths.Any(p => path == p || path == p + "/");
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _isLandingPage = IsLandingPage(e.Location);
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("dismissSplash"); } catch { }
        }
    }

    private async Task ToggleTheme()
    {
        var result = await JS.InvokeAsync<string>("toggleTheme");
        _isDark = result == "dark";
        StateHasChanged();
    }

    private async Task ToggleLang()
    {
        var lang = T.CurrentLanguage == "fa" ? "en" : "fa";
        await T.LoadLanguageAsync(lang);
        AppState.NotifyStateChanged();
    }

    private async Task ToggleSidebar()
    {
        _sidebarOpen = !_sidebarOpen;
        await JS.InvokeVoidAsync("toggleAdminSidebar", _sidebarOpen);
    }

    private void Logout()
    {
        Auth.Logout();
    }

    private void OnAuthChanged()
    {
        AppState.NotifyStateChanged();
    }

    private void OnAppStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Auth.OnAuthStateChanged -= OnAuthChanged;
        AppState.OnStateChanged -= OnAppStateChanged;
        T.OnLanguageChanged -= OnLanguageChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
