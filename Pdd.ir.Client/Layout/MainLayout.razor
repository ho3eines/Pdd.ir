@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject AuthService Auth
@inject NavigationManager Navigation
@implements IDisposable

@if (_isLandingPage)
{
    @Body
}
else
{
    <div class="page">
        <div class="sidebar" id="sidebar">
            <NavMenu OnToggleSidebar="ToggleSidebar" />
        </div>

        <main>
            <div class="top-row px-3 d-flex align-items-center justify-content-between">
                <button class="btn btn-sm btn-outline-secondary d-md-none" @onclick="ToggleSidebar">
                    <i class="bi bi-list"></i>
                </button>
                <div class="d-flex align-items-center gap-3">
                    <div class="connection-status">
                        <span class="connection-dot @(_isConnected ? "connected" : "disconnected")"></span>
                        <span>@(_isConnected ? "WS" : "API")</span>
                    </div>
                    <div class="theme-toggle" @onclick="ToggleTheme" title="تغییر تم">
                        <i class="bi @(_isDark ? "bi-sun" : "bi-moon")"></i>
                    </div>
                    @if (Auth.IsAuthenticated)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-secondary" style="font-size:0.85rem;">@Auth.FullName</span>
                            <button class="btn btn-sm btn-outline-danger" @onclick="Logout">
                                <i class="bi bi-box-arrow-right"></i>
                            </button>
                        </div>
                    }
                </div>
            </div>

            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>
}

@code {
    private bool _isDark = true;
    private bool _isConnected;
    private bool _isLandingPage;

    [Inject] private ConnectionService Connection { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        Auth.OnAuthStateChanged += StateHasChanged;
        Connection.OnConnectionChanged += OnConnectionChanged;
        Navigation.LocationChanged += OnLocationChanged;

        _isLandingPage = IsLandingPage(Navigation.Uri);

        if (!_isLandingPage)
        {
            await Auth.LoadFromStorageAsync();
            if (!Auth.IsAuthenticated)
            {
                Navigation.NavigateTo("/login", true);
                return;
            }
        }

        try
        {
            var theme = await JS.InvokeAsync<string>("localStorage.getItem", "theme");
            _isDark = theme != "light";
        }
        catch { }
    }

    private bool IsLandingPage(string uri)
    {
        var path = new Uri(uri).AbsolutePath.ToLower();
        var landingPaths = new[] { "/", "/products", "/blog", "/portfolio", "/about", "/contact" };
        return landingPaths.Any(p => path == p || path == p + "/");
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _isLandingPage = IsLandingPage(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private void OnConnectionChanged(bool connected)
    {
        _isConnected = connected;
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("dismissSplash"); } catch { }
        }
    }

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("localStorage.setItem", "theme", _isDark ? "dark" : "light");
        await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme', '{(_isDark ? "dark" : "light")}')");
    }

    private void ToggleSidebar()
    {
    }

    private void Logout()
    {
        Auth.Logout();
    }

    public void Dispose()
    {
        Auth.OnAuthStateChanged -= StateHasChanged;
        Connection.OnConnectionChanged -= OnConnectionChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
