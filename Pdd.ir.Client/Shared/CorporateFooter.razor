@inject ITranslateService T

<footer class="footer">
    <div class="container">
        <div class="footer-grid">
            <div>
                <span class="footer-logo-text">PDD</span>
                <span class="footer-logo-name">@T.Text("company_name")</span>
                <p class="footer-desc">
                    @(T.CurrentLanguage == "fa"
                        ? "تولید و پشتیبانی نرم‌افزارهای درمانی با قابلیت بالا و کاربری آسان — ثبت ۲۵۶۳۷۴ با مسئولیت محدود (از سال ۱۳۸۳)"
                        : "Production and support of medical software with high capabilities and easy use — Registration No. 256374 (Since 2004)")
                </p>
            </div>
            <div class="footer-col">
                <h4>@T.Text("products")</h4>
                <ul>
                    <li><a href="/products">HIS — @(T.CurrentLanguage == "fa" ? "بیمارستانی" : "Hospital")</a></li>
                    <li><a href="/products">CIS — @(T.CurrentLanguage == "fa" ? "درمانگاهی" : "Clinic")</a></li>
                    <li><a href="/products">RIS — @(T.CurrentLanguage == "fa" ? "تصویربرداری" : "Imaging")</a></li>
                    <li><a href="/products">LIS — @(T.CurrentLanguage == "fa" ? "آزمایشگاه" : "Laboratory")</a></li>
                    <li><a href="/products">MIS — @(T.CurrentLanguage == "fa" ? "مالی اداری" : "Financial")</a></li>
                    <li><a href="/products">@(T.CurrentLanguage == "fa" ? "اتوماسیون اداری" : "Office Automation")</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>@(T.CurrentLanguage == "fa" ? "شرکت" : "Company")</h4>
                <ul>
                    <li><a href="/about">@T.Text("about")</a></li>
                    <li><a href="/portfolio">@T.Text("portfolio")</a></li>
                    <li><a href="/contact">@T.Text("contact")</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>@T.Text("contact")</h4>
                <ul class="contact-list">
                    <li>
                        <span class="contact-icon"><i class="bi bi-geo-alt"></i></span>
                        <span>@(T.CurrentLanguage == "fa" ? "تهران - شهرک غرب - بلوار دریا" : "Tehran - West Town - Darya Blvd")</span>
                    </li>
                    <li>
                        <span class="contact-icon"><i class="bi bi-telephone"></i></span>
                        <span dir="ltr">021-88368070</span>
                    </li>
                    <li>
                        <span class="contact-icon"><i class="bi bi-envelope"></i></span>
                        <span dir="ltr">pdd_tdp@yahoo.com</span>
                    </li>
                    <li>
                        <span class="contact-icon"><i class="bi bi-globe"></i></span>
                        <span dir="ltr">www.pdd.ir</span>
                    </li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>© @(T.CurrentLanguage == "fa" ? "۱۳۸۳-۱۴۰۵" : "2004-2026") @T.Text("company_name") — @T.Text("all_rights_reserved")</p>
        </div>
    </div>
</footer>
