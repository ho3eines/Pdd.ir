@inject IModalService Modal
@inject IAlertService Alert
@inject ICommunicationService Comm
@inject ITranslateService T

<div class="aco-dialog-body">
    <div style="background:var(--bg-tertiary);border-radius:12px;padding:12px 16px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
            <i class="bi bi-info-circle" style="color:var(--pdd-primary);"></i>
            <strong style="font-size:0.875rem;">@T.Text("change_password")</strong>
        </div>
        <p style="margin:0;font-size:0.8125rem;color:var(--text-secondary);">@T.Text("new_password_guide") @Username</p>
    </div>
    <div class="mb-3">
        <label class="form-label">@T.Text("new_password") *</label>
        <input type="password" class="form-control" @bind="NewPassword" />
    </div>
</div>
<div class="aco-dialog-footer">
    <button class="btn btn-secondary" @onclick="Close">@T.Text("cancel")</button>
    <button class="btn btn-primary" @onclick="Save" disabled="@IsSaving">
        @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
        <i class="bi bi-floppy me-1"></i>@T.Text("save")
    </button>
</div>

@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public string Username { get; set; } = "";

    string NewPassword = "";
    bool IsSaving = false;

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(NewPassword))
        {
            await Alert.ShowWarningAsync(T.Text("warning"), T.Text("password_required"));
            return;
        }

        IsSaving = true;
        try
        {
            await Comm.PostAsync<object>($"api/user/{UserId}/password", new { Password = NewPassword });
            await Alert.ShowSuccessAsync(T.Text("success"), T.Text("password_changed_msg"));
            Modal.Close();
        }
        catch (Exception ex)
        {
            await Alert.ShowErrorAsync(T.Text("error"), ex.Message);
        }
        finally { IsSaving = false; }
    }

    void Close() => Modal.Close();
}
