@inject IModalService Modal
@inject IAlertService Alert
@inject ICommunicationService Comm
@inject ITranslateService T

<div class="aco-dialog-body">
    <div style="background:var(--bg-tertiary);border-radius:12px;padding:12px 16px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
            <i class="bi bi-info-circle" style="color:var(--pdd-primary);"></i>
            <strong style="font-size:0.875rem;">@(IsEdit ? T.Text("blog_edit") : T.Text("blog_new"))</strong>
        </div>
        <p style="margin:0;font-size:0.8125rem;color:var(--text-secondary);">@T.Text("blog_guide")</p>
    </div>
    <div class="row g-3">
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("title") *</label>
            <input type="text" class="form-control" @bind="Model.Title" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">Slug *</label>
            <input type="text" class="form-control" @bind="Model.Slug" />
        </div>
        <div class="col-12">
            <label class="form-label">@T.Text("summary")</label>
            <textarea class="form-control" rows="2" @bind="Model.Summary"></textarea>
        </div>
        <div class="col-12">
            <label class="form-label">@T.Text("content")</label>
            <CKEditorBlazor @bind-CurrentValue="Model.Content" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("author")</label>
            <input type="text" class="form-control" @bind="Model.Author" />
        </div>
        <div class="col-12 col-md-6 d-flex align-items-end">
            <div class="form-check">
                <input type="checkbox" class="form-check-input" @bind="Model.IsPublished" id="publishCheck" />
                <label class="form-check-label" for="publishCheck">@T.Text("published")</label>
            </div>
        </div>
    </div>
</div>
<div class="aco-dialog-footer">
    <button class="btn btn-secondary" @onclick="Close">@T.Text("cancel")</button>
    <button class="btn btn-primary" @onclick="Save" disabled="@IsSaving">
        @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
        <i class="bi bi-floppy me-1"></i>@T.Text("save")
    </button>
</div>

@code {
    [Parameter] public int Id { get; set; }


    BlogDto Model = new();
    bool IsEdit => Id > 0;
    bool IsSaving = false;

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            var item = await Comm.GetAsync<BlogDto>($"api/blog/{Id}");
            if (item != null) Model = item;
        }
        else
        {
            Model = new BlogDto { Author = "Admin", IsPublished = false };
        }
    }

    async Task Save()
    {
        IsSaving = true;
        try
        {
            if (IsEdit)
                await Comm.PutAsync<object>($"api/blog/{Model.Id}", Model);
            else
                await Comm.PostAsync<object>("api/blog", Model);

            await Alert.ShowSuccessAsync(T.Text("success"), T.Text("blog_saved"));
            Modal.Close();
        }
        catch (Exception ex)
        {
            await Alert.ShowErrorAsync(T.Text("error"), ex.Message);
        }
        finally { IsSaving = false; }
    }

    void Close() => Modal.Close();

    public class BlogDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Slug { get; set; } = "";
        public string Summary { get; set; } = "";
        public string Content { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string Author { get; set; } = "";
        public bool IsPublished { get; set; }
        public int ViewCount { get; set; }
    }
}
