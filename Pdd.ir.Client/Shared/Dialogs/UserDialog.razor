@inject IModalService Modal
@inject IAlertService Alert
@inject ICommunicationService Comm
@inject IJSRuntime JS
@inject ITranslateService T

<div class="aco-dialog-body">
    <div style="background:var(--bg-tertiary);border-radius:12px;padding:12px 16px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
            <i class="bi bi-info-circle" style="color:var(--pdd-primary);"></i>
            <strong style="font-size:0.875rem;">@(IsEdit ? T.Text("user_edit") : T.Text("user_new"))</strong>
        </div>
        <p style="margin:0;font-size:0.8125rem;color:var(--text-secondary);">@T.Text("user_guide")</p>
    </div>
    <div class="row g-3">
        @if (!IsEdit)
        {
            <div class="col-12 col-md-6">
                <label class="form-label">@T.Text("username") *</label>
                <input type="text" class="form-control" @bind="Username" />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">@T.Text("password") *</label>
                <input type="password" class="form-control" @bind="Password" />
            </div>
        }
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("full_name")</label>
            <input type="text" class="form-control" @bind="Model.FullName" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("email_field")</label>
            <input type="email" class="form-control" @bind="Model.Email" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("role")</label>
            <SearchableList TItem="RoleItem" TValue="string"
                @bind-Value="Model.Role"
                Items="@_roles"
                TextSelector="@(r => r.Name)"
                ValueSelector="@(r => r.Name)"
                Placeholder="@T.Text("select_role")" />
        </div>
    </div>
</div>
<div class="aco-dialog-footer">
    <button class="btn btn-secondary" @onclick="Close">@T.Text("cancel")</button>
    <button class="btn btn-primary" @onclick="Save" disabled="@IsSaving">
        @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
        <i class="bi bi-floppy me-1"></i>@T.Text("save")
    </button>
</div>

@code {
    [Parameter] public int Id { get; set; }


    UserDto Model = new();
    string Username = "";
    string Password = "";
    bool IsEdit => Id > 0;
    bool IsSaving = false;

    List<RoleItem> _roles = new()
    {
        new("User", "User"),
        new("admin", "Admin"),
        new("manager", "Manager")
    };

    protected override async Task OnInitializedAsync()
    {
        if (IsEdit)
        {
            var item = await Comm.GetAsync<UserDto>($"api/user/{Id}");
            if (item != null) Model = item;
        }
        else
        {
            Model = new UserDto { Role = "User" };
        }
    }

    async Task Save()
    {
        IsSaving = true;
        try
        {
            if (IsEdit)
            {
                await Comm.PutAsync<object>($"api/user/{Model.Id}", new
                {
                    Model.Email, Model.FullName, Model.Role
                });
            }
            else
            {
                if (string.IsNullOrWhiteSpace(Username))
                {
                    await Alert.ShowWarningAsync(T.Text("warning"), T.Text("username_required"));
                    return;
                }
                await Comm.PostAsync<object>("api/user", new
                {
                    Username, Password, Model.Email, Model.FullName, Model.Role
                });
            }

            await Alert.ShowSuccessAsync(T.Text("success"), T.Text("user_saved"));
            Modal.Close();
        }
        catch (Exception ex)
        {
            await Alert.ShowErrorAsync(T.Text("error"), ex.Message);
        }
        finally { IsSaving = false; }
    }

    void Close() => Modal.Close();

    record RoleItem(string Name, string Label);

    public class UserDto
    {
        public int Id { get; set; }
        public string Username { get; set; } = "";
        public string FullName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
        public bool IsActive { get; set; }
    }
}
