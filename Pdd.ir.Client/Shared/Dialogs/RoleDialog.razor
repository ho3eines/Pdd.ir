@inject IModalService Modal
@inject IAlertService Alert
@inject ICommunicationService Comm
@inject ITranslateService T

<div class="aco-dialog-body">
    <div style="background:var(--bg-tertiary);border-radius:12px;padding:12px 16px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
            <i class="bi bi-info-circle" style="color:var(--pdd-primary);"></i>
            <strong style="font-size:0.875rem;">@(IsEdit ? T.Text("role_edit") : T.Text("role_new"))</strong>
        </div>
        <p style="margin:0;font-size:0.8125rem;color:var(--text-secondary);">@T.Text("role_guide")</p>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("role") *</label>
            <input type="text" class="form-control" @bind="FormName" placeholder="e.g. admin, editor" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("description")</label>
            <input type="text" class="form-control" @bind="FormDescription" />
        </div>
    </div>

    <label class="form-label" style="font-weight:700;">@T.Text("permissions")</label>
    @if (!AllPermissions.Any())
    {
        <div class="text-center py-3 text-muted">@T.Text("no_permissions")</div>
    }
    else
    {
        var categories = AllPermissions.Select(p => p.Category).Distinct().ToList();
        @foreach (var cat in categories)
        {
            <div class="mb-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span style="font-size:12px;font-weight:700;color:var(--pdd-primary);text-transform:uppercase;">@cat</span>
                    <button class="btn btn-sm btn-outline-secondary" style="font-size:10px;padding:2px 8px;"
                            @onclick="() => ToggleCategory(cat)">
                        @(IsCategorySelected(cat) ? T.Text("deselect_all") : T.Text("select_all"))
                    </button>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var perm in AllPermissions.Where(p => p.Category == cat))
                    {
                        <label class="d-flex align-items-center gap-1" style="font-size:12px;cursor:pointer;padding:4px 10px;border-radius:8px;border:1px solid var(--border-color);background:var(--bg-tertiary);">
                            <input type="checkbox" checked="@SelectedPermissionIds.Contains(perm.Id)"
                                   @onchange="() => TogglePermission(perm.Id)" />
                            <span>@perm.Label</span>
                        </label>
                    }
                </div>
            </div>
        }
    }
</div>
<div class="aco-dialog-footer">
    <button class="btn btn-secondary" @onclick="Close">@T.Text("cancel")</button>
    <button class="btn btn-primary" @onclick="Save" disabled="@IsSaving">
        @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
        <i class="bi bi-floppy me-1"></i>@T.Text("save")
    </button>
</div>

@code {
    [Parameter] public int Id { get; set; }


    List<PermissionDto> AllPermissions = new();
    string FormName = "";
    string FormDescription = "";
    List<int> SelectedPermissionIds = new();
    bool IsEdit => Id > 0;
    bool IsSaving = false;

    protected override async Task OnInitializedAsync()
    {
        AllPermissions = await Comm.GetAsync<List<PermissionDto>>("api/permission") ?? new();

        if (IsEdit)
        {
            var role = await Comm.GetAsync<RoleDetailDto>($"api/role/{Id}");
            if (role != null)
            {
                FormName = role.Name;
                FormDescription = role.Description;
                SelectedPermissionIds = role.PermissionIds ?? new();
            }
        }
    }

    void TogglePermission(int permId)
    {
        if (SelectedPermissionIds.Contains(permId))
            SelectedPermissionIds.Remove(permId);
        else
            SelectedPermissionIds.Add(permId);
    }

    bool IsCategorySelected(string category)
    {
        var catPerms = AllPermissions.Where(p => p.Category == category).Select(p => p.Id);
        return catPerms.All(id => SelectedPermissionIds.Contains(id));
    }

    void ToggleCategory(string category)
    {
        var catPerms = AllPermissions.Where(p => p.Category == category).Select(p => p.Id).ToList();
        if (IsCategorySelected(category))
            SelectedPermissionIds.RemoveAll(id => catPerms.Contains(id));
        else
            SelectedPermissionIds.AddRange(catPerms.Except(SelectedPermissionIds));
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(FormName))
        {
            await Alert.ShowWarningAsync(T.Text("warning"), T.Text("role_required"));
            return;
        }

        IsSaving = true;
        try
        {
            var payload = new { Name = FormName, Description = FormDescription, PermissionIds = SelectedPermissionIds };

            if (IsEdit)
                await Comm.PutAsync<object>($"api/role/{Id}", payload);
            else
                await Comm.PostAsync<object>("api/role", payload);

            await Alert.ShowSuccessAsync(T.Text("success"), T.Text("role_saved"));
            Modal.Close();
        }
        catch (Exception ex)
        {
            await Alert.ShowErrorAsync(T.Text("error"), ex.Message);
        }
        finally { IsSaving = false; }
    }

    void Close() => Modal.Close();

    public class PermissionDto { public int Id { get; set; } public string Label { get; set; } = ""; public string Category { get; set; } = ""; }
    public class RoleDetailDto { public string Name { get; set; } = ""; public string Description { get; set; } = ""; public List<int>? PermissionIds { get; set; } }
}
