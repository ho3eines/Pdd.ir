@inject IModalService Modal
@inject IAlertService Alert
@inject ICommunicationService Comm

<div class="aco-dialog-body">
    <div class="row g-2 mb-3" style="font-size:13px;">
        <div class="col-6"><strong>نام:</strong> @Message.Name</div>
        <div class="col-6"><strong>ایمیل:</strong> @Message.Email</div>
        <div class="col-6"><strong>تلفن:</strong> @(Message.Phone ?? "-")</div>
        <div class="col-6"><strong>تاریخ:</strong> @DateHelper.ToShamsiWithTime(DateHelper.ToUnix(Message.CreatedAt))</div>
        <div class="col-12"><strong>موضوع:</strong> @(Message.Subject ?? "-")</div>
    </div>
    <hr style="border-color:var(--border-color);" />
    <p style="line-height:1.8;font-size:14px;">@Message.Message</p>
</div>
<div class="aco-dialog-footer">
    <button class="btn btn-secondary" @onclick="Close">بستن</button>
</div>

@code {
    [Parameter] public ContactDto Message { get; set; } = new();
    [Parameter] public EventCallback OnClosed { get; set; }

    void Close()
    {
        OnClosed.InvokeAsync();
        Modal.Close();
    }

    public class ContactDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string? Phone { get; set; }
        public string Subject { get; set; } = "";
        public string Message { get; set; } = "";
        public bool IsRead { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}
