@inject ICommunicationService Comm
@inject IAlertService Alert
@inject ITranslateService T
@inject IModalService Modal

<div class="aco-dialog-body">
    <div style="background:var(--bg-tertiary);border-radius:12px;padding:12px 16px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
            <i class="bi bi-info-circle" style="color:var(--accent-primary);"></i>
            <strong style="font-size:0.875rem;">@T.Text("guide")</strong>
        </div>
        <p style="margin:0;font-size:0.8125rem;color:var(--text-secondary);">
            @T.Text("home_product_dialog_desc")
        </p>
    </div>

    @if (IsLoading)
    {
        <Skeleton Type="card" />
    }
    else
    {
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label class="form-label">@T.Text("name_fa") *</label>
                <input type="text" class="form-control" @bind="Model.NameFa" />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">@T.Text("name_en") *</label>
                <input type="text" class="form-control" @bind="Model.NameEn" />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">@T.Text("sub_fa")</label>
                <input type="text" class="form-control" @bind="Model.SubFa" />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">@T.Text("sub_en")</label>
                <input type="text" class="form-control" @bind="Model.SubEn" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">@T.Text("icon")</label>
                <input type="text" class="form-control" @bind="Model.Icon" placeholder="bi-hospital" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">@T.Text("icon_bg")</label>
                <input type="text" class="form-control" @bind="Model.IconBg" placeholder="rgba(13,110,253,0.15)" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label">@T.Text("icon_color")</label>
                <input type="text" class="form-control" @bind="Model.IconColor" placeholder="#0D6EFD" />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">@T.Text("route")</label>
                <input type="text" class="form-control" @bind="Model.Route" placeholder="/products" />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">@T.Text("sort_order")</label>
                <input type="number" class="form-control" @bind="Model.SortOrder" />
            </div>
        </div>
    }
</div>

<div class="aco-dialog-footer">
    <button class="btn btn-secondary" @onclick="Close">@T.Text("cancel")</button>
    <button class="btn btn-primary" @onclick="Save" disabled="@(IsSaving || IsLoading)">
        @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
        else { <i class="bi bi-floppy me-1"></i> }
        @T.Text("save")
    </button>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    HomeProductDto Model = new();
    bool IsLoading = true;
    bool IsSaving = false;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var item = await Comm.GetAsync<HomeProductDto>($"api/homeproduct/{Id}");
            if (item != null) Model = item;
        }
        else
        {
            Model = new HomeProductDto();
        }
        IsLoading = false;
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(Model.NameFa))
        {
            await Alert.ShowWarningAsync(T.Text("warning"), T.Text("name_required"));
            return;
        }

        IsSaving = true;
        try
        {
            if (Id.HasValue)
                await Comm.PutAsync<object>($"api/homeproduct/{Id}", Model);
            else
                await Comm.PostAsync<object>("api/homeproduct", Model);

            await Alert.ShowSuccessAsync(T.Text("success"), T.Text("saved_successfully"));
            Modal.Close();
        }
        catch (Exception ex)
        {
            await Alert.ShowErrorAsync(T.Text("error"), ex.Message);
        }
        finally
        {
            IsSaving = false;
        }
    }

    void Close() => Modal.Close();
}
