@inject ICommunicationService Comm
@inject IAlertService Alert
@inject ITranslateService T
@inject IModalService Modal

<div class="aco-dialog-body">
    <div style="background:var(--bg-tertiary);border-radius:12px;padding:12px 16px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
            <i class="bi bi-info-circle" style="color:var(--accent-primary);"></i>
            <strong style="font-size:0.875rem;">@T.Text("guide")</strong>
        </div>
        <p style="margin:0;font-size:0.8125rem;color:var(--text-secondary);">
            @T.Text("client_dialog_description")
        </p>
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("name_fa") *</label>
            <input type="text" class="form-control" @bind="Model.Name" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("name_en")</label>
            <input type="text" class="form-control" @bind="Model.NameEn" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("icon")</label>
            <input type="text" class="form-control" @bind="Model.Icon" placeholder="bi-hospital" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("color")</label>
            <input type="color" class="form-control form-control-color" @bind="Model.Color" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("sort_order")</label>
            <input type="number" class="form-control" @bind="Model.SortOrder" />
        </div>
    </div>
</div>

<div class="aco-dialog-footer">
    <button class="btn btn-secondary" @onclick="Close">@T.Text("cancel")</button>
    <button class="btn btn-primary" @onclick="Save" disabled="@IsSaving">
        @if (IsSaving)
        {
            <span class="spinner-border spinner-border-sm me-1"></span>
        }
        else
        {
            <i class="bi bi-floppy me-1"></i>
        }
        @T.Text("save")
    </button>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    ClientDto Model = new();
    bool IsSaving = false;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var item = await Comm.GetAsync<ClientDto>($"api/client/{Id}");
            if (item != null) Model = item;
        }
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(Model.Name))
        {
            await Alert.ShowWarningAsync(T.Text("warning"), T.Text("name_required"));
            return;
        }

        IsSaving = true;
        try
        {
            if (Id.HasValue)
                await Comm.PutAsync<object>($"api/client/{Id}", Model);
            else
                await Comm.PostAsync<object>("api/client", Model);

            await Alert.ShowSuccessAsync(T.Text("success"), T.Text("saved_successfully"));
            Modal.Close();
        }
        catch (Exception ex)
        {
            await Alert.ShowErrorAsync(T.Text("error"), ex.Message);
        }
        finally
        {
            IsSaving = false;
        }
    }

    void Close() => Modal.Close();
}
