@inject ICommunicationService Comm
@inject IAlertService Alert
@inject ITranslateService T
@inject IModalService Modal
@inject IFileUploadService FileUpload

<div class="aco-dialog-body">
    <div style="background:var(--bg-tertiary);border-radius:12px;padding:12px 16px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
            <i class="bi bi-info-circle" style="color:var(--accent-primary);"></i>
            <strong style="font-size:0.875rem;">@T.Text("guide")</strong>
        </div>
        <p style="margin:0;font-size:0.8125rem;color:var(--text-secondary);">
            @T.Text("client_dialog_description")
        </p>
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("name_fa") *</label>
            <input type="text" class="form-control" @bind="Model.Name" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("name_en")</label>
            <input type="text" class="form-control" @bind="Model.NameEn" />
        </div>
        <div class="col-12">
            <label class="form-label">@T.Text("image")</label>
            <FileUpload Label="@T.Text("upload_image")"
                        Accept="image/*"
                        MaxFileSizeMB="5"
                        CurrentUrl="@Model.ImageUrl"
                        OnFileUploaded="OnImageUploaded" />
        </div>
        <div class="col-12 col-md-6">
            <label class="form-label">@T.Text("sort_order")</label>
            <input type="number" class="form-control" @bind="Model.SortOrder" />
        </div>
    </div>
</div>

<div class="aco-dialog-footer">
    <button class="btn btn-secondary" @onclick="Close">@T.Text("cancel")</button>
    <button class="btn btn-primary" @onclick="Save" disabled="@IsSaving">
        @if (IsSaving)
        {
            <span class="spinner-border spinner-border-sm me-1"></span>
        }
        else
        {
            <i class="bi bi-floppy me-1"></i>
        }
        @T.Text("save")
    </button>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    ClientDto Model = new();
    bool IsSaving = false;
    string? _pendingImageData;

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            var item = await Comm.GetAsync<ClientDto>($"api/client/{Id}");
            if (item != null)
            {
                Model = item;
                
                // If ImageUrl is a file path (not data URL), fetch via API
                if (!string.IsNullOrEmpty(Model.ImageUrl) && !Model.ImageUrl.StartsWith("data:"))
                {
                    var imageUrl = await FetchImageViaHttp(Model.ImageUrl);
                    if (!string.IsNullOrEmpty(imageUrl))
                    {
                        Model.ImageUrl = imageUrl;
                    }
                }
            }
        }
    }

    async Task<string?> FetchImageViaHttp(string imagePath)
    {
        try
        {
            // imagePath شامل GUID هست (مثلاً: "abc123")
            var file = await FileUpload.GetFileAsync(imagePath);
            if (file != null)
            {
                return $"data:{file.contentType};base64,{file.base64}";
            }
            return null;
        }
        catch
        {
            return null;
        }
    }

    void OnImageUploaded(string dataUrl)
    {
        // Store data URL temporarily
        _pendingImageData = dataUrl;
        // Show preview
        Model.ImageUrl = dataUrl;
        StateHasChanged();
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(Model.Name))
        {
            await Alert.ShowWarningAsync(T.Text("warning"), T.Text("name_required"));
            return;
        }

        IsSaving = true;
        try
        {
            // If there's a new image (data URL), upload it via HTTP first
            if (!string.IsNullOrEmpty(Model.ImageUrl) && Model.ImageUrl.StartsWith("data:"))
            {
                var imageUrl = await UploadImageViaHttp(Model.ImageUrl);
                if (!string.IsNullOrEmpty(imageUrl))
                {
                    Model.ImageUrl = imageUrl;  // GUID
                }
            }

            // Now save the client with the GUID (not data URL)
            if (Id.HasValue)
                await Comm.PutAsync<object>($"api/client/{Id}", Model);
            else
                await Comm.PostAsync<object>("api/client", Model);

            await Alert.ShowSuccessAsync(T.Text("success"), T.Text("saved_successfully"));
            Modal.Close();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[Save] Error: {ex.Message}");
            await Alert.ShowErrorAsync(T.Text("error"), ex.Message);
        }
        finally
        {
            IsSaving = false;
        }
    }

    async Task<string?> UploadImageViaHttp(string dataUrl)
    {
        try
        {
            return await FileUpload.UploadImageAsync(dataUrl);
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Upload error: {ex.Message}");
            return null;
        }
    }

    void Close() => Modal.Close();

    public class FileUploadResult
    {
        public bool success { get; set; }
        public FileData? data { get; set; }
    }

    public class FileData
    {
        public string url { get; set; } = "";
        public string fileName { get; set; } = "";
    }
}
