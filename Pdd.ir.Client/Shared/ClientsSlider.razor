@inject ICommunicationService Comm
@inject ITranslateService T
@inject IFileUploadService FileUpload

<section class="clients-section">
    <div class="clients-track">
        @foreach (var client in _clients.Concat(_clients))
        {
            <div class="client-logo">
                @if (!string.IsNullOrEmpty(client.ImageUrl))
                {
                    <img src="@client.ImageUrl" 
                         alt="@(T.CurrentLanguage == "fa" ? client.Name : client.NameEn)" 
                         style="width:50px;height:50px;object-fit:contain;" />
                }
                else
                {
                    <div class="cs-icon" style="background:#0D6EFD;color:#fff;">
                        <i class="bi bi-hospital"></i>
                    </div>
                }
                <span class="cs-name">@(T.CurrentLanguage == "fa" ? client.Name : client.NameEn)</span>
            </div>
        }
    </div>
</section>

@code {
    private List<ClientImage> _clients = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // دریافت لیست مشتریان از سرور
            var response = await Comm.GetAsync<ClientListResponse>("api/client");
            if (response?.success == true && response.data != null)
            {
                _clients = response.data;
            }
        }
        catch
        {
            _clients = new();
        }
    }

    public class ClientImage
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string NameEn { get; set; } = "";
        public string? ImageUrl { get; set; }
    }

    public class ClientListResponse
    {
        public bool success { get; set; }
        public List<ClientImage>? data { get; set; }
    }
}
