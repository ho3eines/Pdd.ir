<section class="clients-section">
    <div class="clients-track">
        @foreach (var logo in _logos.Concat(_logos))
        {
            <div class="client-logo">
                <i class="@logo.Icon"></i>
                <span>@logo.Name</span>
            </div>
        }
    </div>
</section>

@code {
    private List<LogoItem> _logos => new()
    {
        new("bi bi-hospital", "بیمارستان قائم جیرفت"),
        new("bi bi-hospital", "بیمارستان محمد کرمانشاهی"),
        new("bi bi-hospital", "بیمارستان شفا ساری"),
        new("bi bi-hospital", "بیمارستان حضرت فاطمه ساوه"),
        new("bi bi-hospital", "بیمارستان نیکوکاری"),
        new("bi bi-hospital", "بیمارستان محب مهر"),
        new("bi bi-hospital", "بیمارستان چمران"),
        new("bi bi-hospital", "بیمارستان امام خمینی"),
        new("bi bi-hospital", "بیمارستان گلستان"),
        new("bi bi-hospital", "بیمارستان شهید بهشتی"),
    };

    private record LogoItem(string Icon, string Name);
}
