@inject ICommunicationService Comm
@inject ITranslateService T

<section class="clients-section">
    <div class="clients-track">
        @foreach (var client in _clients.Concat(_clients))
        {
            <div class="client-logo">
                <div class="cs-icon" style="background:@client.Color;color:#fff;">
                    <i class="bi @client.Icon"></i>
                </div>
                <span class="cs-name">@(T.CurrentLanguage == "fa" ? client.Name : client.NameEn)</span>
            </div>
        }
    </div>
</section>

@code {
    private List<ClientDto> _clients = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _clients = await Comm.GetAsync<List<ClientDto>>("api/client") ?? new();
        }
        catch
        {
            // Fallback to empty list
            _clients = new();
        }
    }
}
