@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop

@inherits InputTextArea
@inject IJSRuntime JSRuntime

<textarea @attributes="AdditionalAttributes"
          id="@Id"
          class="form-control @CssClass"
          value="@CurrentValue"></textarea>

@code {
    string _id = "";

    [Parameter]
    public string Id
    {
        get => _id ?? $"CKEditor_{uid}";
        set => _id = value;
    }

    [Parameter]
    public string? UploadUrl { get; set; }

    readonly string uid = Guid.NewGuid().ToString().ToLower().Replace("-", "");

    protected override async Task OnInitializedAsync()
    {
        await LoadScripts();
        await base.OnInitializedAsync();
    }

    private async Task LoadScripts()
    {
        await JSRuntime.InvokeVoidAsync("eval",
            "new Promise((resolve, reject) => {" +
            "  if (typeof CKEDITOR !== 'undefined') resolve();" +
            "  const script = document.createElement('script');" +
            "  script.src = '/_content/Pdd.ir.Shared/js/ckeditor.js';" +
            "  script.onload = () => resolve();" +
            "  script.onerror = () => reject();" +
            "  document.head.appendChild(script);" +
            "})");

        await JSRuntime.InvokeVoidAsync("eval",
            "new Promise((resolve, reject) => {" +
            "  if (window.CKEditorInterop) resolve();" +
            "  const script = document.createElement('script');" +
            "  script.src = '/_content/Pdd.ir.Shared/js/CKEditorInterop.js';" +
            "  script.onload = () => resolve();" +
            "  script.onerror = () => reject();" +
            "  document.head.appendChild(script);" +
            "})");

        await JSRuntime.InvokeVoidAsync("CKEditorInterop.init", Id, UploadUrl, DotNetObjectReference.Create(this));
    }

    [JSInvokable]
    public Task EditorDataChanged(string data)
    {
        CurrentValue = data;
        StateHasChanged();
        return Task.CompletedTask;
    }

    protected override void Dispose(bool disposing)
    {
        JSRuntime.InvokeVoidAsync("CKEditorInterop.destroy", Id);
        base.Dispose(disposing);
    }
}
