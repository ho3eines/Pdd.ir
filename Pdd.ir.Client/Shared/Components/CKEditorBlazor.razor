@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop

@implements IDisposable
@inject IJSRuntime JSRuntime

<textarea @attributes="AdditionalAttributes"
          id="@Id"
          class="form-control @CssClass"
          value="@Value"
          @oninput="OnInput"></textarea>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Id { get; set; } = $"CKEditor_{Guid.NewGuid().ToString("N")[..8]}";
    [Parameter] public string? UploadUrl { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private async Task OnInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString() ?? "";
        await ValueChanged.InvokeAsync(Value);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadScripts();
    }

    private async Task LoadScripts()
    {
        await JSRuntime.InvokeVoidAsync("eval",
            "new Promise((resolve, reject) => {" +
            "  if (typeof CKEDITOR !== 'undefined') resolve();" +
            "  const script = document.createElement('script');" +
            "  script.src = '/js/ckeditor.js';" +
            "  script.onload = () => resolve();" +
            "  script.onerror = () => reject();" +
            "  document.head.appendChild(script);" +
            "})");

        await JSRuntime.InvokeVoidAsync("eval",
            "new Promise((resolve, reject) => {" +
            "  if (window.CKEditorInterop) resolve();" +
            "  const script = document.createElement('script');" +
            "  script.src = '/js/CKEditorInterop.js';" +
            "  script.onload = () => resolve();" +
            "  script.onerror = () => reject();" +
            "  document.head.appendChild(script);" +
            "})");

        await JSRuntime.InvokeVoidAsync("CKEditorInterop.init", Id, UploadUrl, DotNetObjectReference.Create(this));
    }

    [JSInvokable]
    public async Task EditorDataChanged(string data)
    {
        Value = data;
        await ValueChanged.InvokeAsync(Value);
        StateHasChanged();
    }

    public void Dispose()
    {
        JSRuntime.InvokeVoidAsync("CKEditorInterop.destroy", Id);
    }
}
